  say "ENV_FILE      = $ENV_FILE"
  say "DNS_FILE      = $DNS_FILE"
  say "PROFILE_FILE  = $PROFILE_FILE"
  say "FINAL_CONFIG  = $FINAL_CONFIG"
  say "MIHOMO_BIN    = $MIHOMO_BIN"
  say "UI_DIR        = $UI_DIR"
  say "LOG_FILE      = $MIHOMO_LOG_FILE"
  say "PID_FILE      = $MIHOMO_PID_FILE"
