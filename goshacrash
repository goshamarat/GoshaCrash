language_menu() {
  while true; do
    header "$(msg language)"
    say "Current: $GC_LANGUAGE"
    say ""
    say "1) Русский"
    say "2) English"
    say "0) $(msg back)"
    say ""
    ask "$(msg choose)"

    IFS= read -r choice

    case "$choice" in
      1|ru)
        save_language ru
        say "$(msg lang_saved): ru"
        pause
        return
        ;;
      2|en)
        save_language en
        say "$(msg lang_saved): en"
        pause
        return
        ;;
      0|q|Q)
        return
        ;;
      *)
        say "$(msg unknown): $choice"
        pause
        ;;
    esac
  done
}

