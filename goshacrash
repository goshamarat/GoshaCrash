install_ui() {
  ensure_custom_files
  load_env
  init_dirs

  banner
  small_header "Install Zashboard"

  if ! has_cmd unzip; then
    badge_no "unzip is required"
    say ""
    say "Install it manually:"
    say "  ASUS Optware: ipkg install unzip"
    say "  ASUS Entware: opkg install unzip"
    say "  WSL/Linux: sudo apt install unzip"
    return 1
  fi

  release_json="$TMP_DIR/zashboard-release.json"
  get_release_json "$ZASHBOARD_REPO_OWNER" "$ZASHBOARD_REPO_NAME" "$release_json" || die "failed to fetch Zashboard release info"

  url="$(find_asset_url "$release_json" 'dist\.zip$ zashboard.*\.zip$')"

  if [ -z "$url" ]; then
    badge_no "No suitable Zashboard asset found"
    say ""
    say "Available assets:"
    list_release_assets "$release_json"
    return 1
  fi

  badge_info "Downloading:"
  say "$url"

  download "$TMP_DIR/zashboard.zip" "$url" || die "failed to download Zashboard"

  rm -rf "$UI_DIR"
  mkdir -p "$UI_DIR"

  unzip -q "$TMP_DIR/zashboard.zip" -d "$UI_DIR" || die "failed to unpack Zashboard"

  if [ -f "$UI_DIR/index.html" ]; then
    badge_ok "Zashboard installed: $UI_DIR"
  else
    badge_warn "index.html not found directly in UI_DIR"
    find "$UI_DIR" -maxdepth 2 -type f | head -n 20
  fi
}

doctor() {
  ensure_custom_files
  load_env

  banner
  small_header "System"
  say "Target:       $(detect_target)"
  say "Arch:         $(detect_arch)"
  say "User:         $(whoami)"
  say "Home:         $HOME"
  say "Script dir:   $SCRIPT_DIR"
  say "Base dir:     $BASE_DIR"
  say "Custom dir:   $CUSTOM_DIR"
  say "Kernel:"
  say "  $(uname -a)"

  small_header "Tools"
  for cmd in sh curl wget gzip gunzip tar unzip grep sed awk nano mcedit ipkg opkg apt-get ip iptables ss; do
    if has_cmd "$cmd"; then
      badge_ok "$cmd: $(command -v "$cmd")"
    else
      badge_no "$cmd"
    fi
  done

  small_header "Files"
  for file in "$ENV_FILE" "$DNS_FILE" "$CUSTOM_CONFIG_FILE" "$TARGET_CONFIG_FILE" "$MIHOMO_BIN"; do
    if [ -f "$file" ]; then
      badge_ok "$file"
    else
      badge_warn "$file missing"
    fi
  done

  small_header "Editor"
  if editor_cmd="$(detect_editor 2>/dev/null)"; then
    badge_ok "$editor_cmd"
  else
    badge_warn "not found"
  fi
}

