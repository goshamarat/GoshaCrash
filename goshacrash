# Automatic WAN watchdog. It runs only while Mihomo is running.
# It never reboots the router and never rewrites config.yaml/runtime.yaml.
WATCHDOG_PIDFILE="$BASE/run/watchdog.pid"
WATCHDOG_LOG="$BASE/logs/watchdog.log"
WATCHDOG_INTERVAL="${GOSHACRASH_WATCHDOG_INTERVAL:-60}"
WATCHDOG_FAIL_THRESHOLD="${GOSHACRASH_WATCHDOG_FAIL_THRESHOLD:-3}"
WATCHDOG_BOOT_GRACE="${GOSHACRASH_WATCHDOG_BOOT_GRACE:-120}"
WATCHDOG_ACTION_COOLDOWN="${GOSHACRASH_WATCHDOG_ACTION_COOLDOWN:-600}"
WATCHDOG_URLS="${GOSHACRASH_WATCHDOG_URLS:-https://www.gstatic.com/generate_204 https://cp.cloudflare.com/generate_204}"

PATH="/usr/sbin:/usr/bin:/sbin:/bin:/opt/bin:/opt/sbin:/tmp/opt/bin:/tmp/opt/sbin:$USB_MOUNT/asusware.arm/bin:$USB_MOUNT/asusware.arm/sbin:$USB_MOUNT/asusware.arm/opt/bin:$USB_MOUNT/asusware.arm/opt/sbin:$USB_MOUNT/asusware.arm/usr/bin"
export PATH

say(){ printf '%s\n' "[GoshaCrash] $*"; }
warn(){ printf '%s\n' "[GoshaCrash:WARN] $*" >&2; }
fail(){ printf '%s\n' "[GoshaCrash:ERROR] $*" >&2; return 1; }
have(){ which "$1" >/dev/null 2>&1; }

ensure_dirs(){ mkdir -p "$BASE/bin" "$UI" "$BASE/run" "$BASE/logs" "$BACKUPS" "$STATE"; }

is_true(){
    case "$1" in true|True|TRUE|yes|Yes|YES|1|on|On|ON) return 0;; esac
    return 1
}

strip_value(){
    printf '%s\n' "$1" | sed -e 's/[[:space:]]*#.*$//' -e 's/^[[:space:]]*//' \
        -e 's/[[:space:]]*$//' -e 's/^"//' -e 's/"$//' -e "s/^'//" -e "s/'$//"
}

yaml_top(){
    f="$1"; k="$2"
    v="$(awk -v k="$k" '$0 ~ "^[[:space:]]*" k ":[[:space:]]*" {x=$0; sub("^[[:space:]]*" k ":[[:space:]]*","",x); print x; exit}' "$f" 2>/dev/null)"
    strip_value "$v"
}

yaml_section(){
    f="$1"; s="$2"; k="$3"
    v="$(awk -v s="$s" -v k="$k" '
        $0 ~ "^" s ":[[:space:]]*($|#)" {inside=1; next}
        inside && /^[^[:space:]#]/ {exit}
        inside && $0 ~ "^[[:space:]]+" k ":[[:space:]]*" {x=$0; sub("^[[:space:]]+" k ":[[:space:]]*","",x); print x; exit}
    ' "$f" 2>/dev/null)"
    strip_value "$v"
}

lan_ifaces(){
    [ -n "${GOSHACRASH_LAN_IFACES:-}" ] && { echo "$GOSHACRASH_LAN_IFACES"; return; }
    x="$(nvram get lan_ifname 2>/dev/null)"; [ -n "$x" ] || x=br0; echo "$x"
}

lan_ip(){ x="$(nvram get lan_ipaddr 2>/dev/null)"; [ -n "$x" ] || x=192.168.1.1; echo "$x"; }

fetch(){
    url="$1"; out="$2"; part="$out.part.$$"; log="/tmp/goshacrash-fetch.$$"
    rm -f "$part" "$out" "$log"

    if [ -x /usr/sbin/wget ]; then
        downloader=/usr/sbin/wget; kind=wget
    elif have wget; then
        downloader="$(which wget)"; kind=wget
    elif have curl; then
        downloader="$(which curl)"; kind=curl
    else
        fail "Не найден wget или curl"
        return 1
    fi

    say "Загрузчик: $downloader"
    if [ "$kind" = wget ]; then
        "$downloader" --no-check-certificate -O "$part" "$url" >"$log" 2>&1
    else
        "$downloader" -k -f -L -o "$part" "$url" >"$log" 2>&1
    fi
    rc=$?

    if [ "$rc" -eq 0 ] && [ -s "$part" ]; then
        mv -f "$part" "$out"
        rm -f "$log"
        return 0
    fi

    warn "Не удалось скачать $url"
    [ -s "$log" ] && cat "$log" >&2
    rm -f "$part" "$out" "$log"
    return 1
}

fetch_any(){
    out="$1"
    shift
    for url in "$@"; do
        [ -n "$url" ] || continue
        say "Пробую скачать: $url"
        if fetch "$url" "$out"; then
            return 0
        fi
    done
    return 1
}

is_asus(){
    have nvram && [ -n "$(nvram get productid 2>/dev/null)" ] && return 0
    uname -a 2>/dev/null | grep -qiE 'asus|brcmarm'
}

core_arch(){
    case "$(uname -m 2>/dev/null)" in
        armv7l|armv7*|armhf)
            # ShellCrash uses armv5 on old ASUS armv7 devices to avoid crashes.
            if is_asus; then echo armv5; else echo armv7; fi;;
        armv5*|armv6*) echo armv5;;
        aarch64|arm64) echo arm64;;
        x86_64|amd64) echo amd64;;
        i?86|x86) echo 386;;
        *) fail "Неподдерживаемая архитектура: $(uname -m)"; return 1;;
    esac
}

install_core_from_shellcrash(){
    a="$1"
    pkg="$BASE/run/mihomo-shellcrash.tar.gz"
    ex="$BASE/run/mihomo.extract"
    new="$BASE/run/mihomo.new"
    asset="clash-linux-$a.tar.gz"

    if [ -n "${MIHOMO_URL:-}" ]; then
        fetch_any "$pkg" "$MIHOMO_URL" || return 1
    else
        fetch_any "$pkg" \
            "https://testingcf.jsdelivr.net/gh/$SHELLCRASH_REPO@$SHELLCRASH_BRANCH/bin/meta/$asset" \
            "https://cdn.jsdelivr.net/gh/$SHELLCRASH_REPO@$SHELLCRASH_BRANCH/bin/meta/$asset" \
            "https://raw.githubusercontent.com/$SHELLCRASH_REPO/$SHELLCRASH_BRANCH/bin/meta/$asset" \
            "https://github.com/$SHELLCRASH_REPO/raw/$SHELLCRASH_BRANCH/bin/meta/$asset" || return 1
    fi

    tar -tzf "$pkg" >/dev/null 2>&1 || {
        warn "Получен повреждённый архив Mihomo"
        rm -f "$pkg"
        return 1
    }

    rm -rf "$ex"
    mkdir -p "$ex" || return 1
    tar -xzf "$pkg" -C "$ex" >/dev/null 2>&1 || {
        rm -rf "$ex" "$pkg"
        return 1
    }

    candidate=""
    for f in "$ex/CrashCore" "$ex/clash" "$ex/mihomo" "$ex"/*; do
        [ -f "$f" ] || continue
        candidate="$f"
        break
    done

    [ -n "$candidate" ] && [ -f "$candidate" ] || {
        rm -rf "$ex" "$pkg"
        fail "В архиве Mihomo не найден бинарник"
        return 1
    }

    cp "$candidate" "$new" || return 1
    chmod 755 "$new" || return 1
    "$new" -v >/dev/null 2>&1 || {
        warn "Скачанное ядро Mihomo не запускается"
        rm -rf "$ex" "$pkg" "$new"
        return 1
    }

    rm -rf "$ex" "$pkg"
    return 0
}

install_core(){
    ensure_dirs || return 1
    a="$(core_arch)" || return 1
    new="$BASE/run/mihomo.new"
    rm -f "$new"

    say "Архитектура ядра: $a"
    install_core_from_shellcrash "$a" || {
        fail "Не удалось скачать рабочее ядро Mihomo из основного источника"
        return 1
    }

    [ -f "$BIN" ] && cp "$BIN" "$BIN.previous" 2>/dev/null || true
    mv -f "$new" "$BIN" || return 1
    chmod 755 "$BIN" || return 1
    say "Mihomo установлен: $($BIN -v 2>/dev/null | head -n 1)"
}

find_ui_root(){
    ex="$1"
    [ -f "$ex/index.html" ] && { echo "$ex"; return 0; }
    for d in "$ex"/*; do
        [ -d "$d" ] && [ -f "$d/index.html" ] && { echo "$d"; return 0; }
    done
    if have find; then
        idx="$(find "$ex" -name index.html -type f 2>/dev/null | head -n 1)"
        [ -n "$idx" ] && { dirname "$idx"; return 0; }
    fi
    return 1
}

install_ui(){
    ensure_dirs || return 1
    tgz="$BASE/run/zashboard.tar.gz"
    ex="$BASE/run/zashboard.extract"
    newui="$BASE/run/ui.new"
    rm -rf "$ex" "$newui"
    mkdir -p "$ex" "$newui" || return 1

    if [ -n "${ZASHBOARD_URL:-}" ]; then
        fetch_any "$tgz" "$ZASHBOARD_URL" || return 1
    else
        fetch_any "$tgz" \
            "https://testingcf.jsdelivr.net/gh/$SHELLCRASH_REPO@$SHELLCRASH_BRANCH/bin/dashboard/zashboard.tar.gz" \
            "https://cdn.jsdelivr.net/gh/$SHELLCRASH_REPO@$SHELLCRASH_BRANCH/bin/dashboard/zashboard.tar.gz" \
            "https://raw.githubusercontent.com/$SHELLCRASH_REPO/$SHELLCRASH_BRANCH/bin/dashboard/zashboard.tar.gz" \
            "https://github.com/$SHELLCRASH_REPO/raw/$SHELLCRASH_BRANCH/bin/dashboard/zashboard.tar.gz" || return 1
    fi

    tar -tzf "$tgz" >/dev/null 2>&1 || {
        fail "Получен повреждённый архив Zashboard"
        rm -f "$tgz"
        return 1
    }
    tar -xzf "$tgz" -C "$ex" >/dev/null 2>&1 || return 1
    ui_root="$(find_ui_root "$ex")" || {
        fail "В архиве Zashboard нет index.html"
        rm -rf "$ex" "$tgz"
        return 1
    }
    cp -R "$ui_root"/. "$newui"/ || return 1
    [ -f "$newui/index.html" ] || return 1

    rm -rf "$UI.previous"
    [ -d "$UI" ] && mv "$UI" "$UI.previous" 2>/dev/null || true
    mv "$newui" "$UI" || {
        [ -d "$UI.previous" ] && mv "$UI.previous" "$UI"
        return 1
    }
    rm -rf "$ex" "$tgz"
    say "Zashboard установлен по сети"
}

detect_dns_mode(){
    f="$1"
    listen="$(
        awk '
        {
            line=$0
            sub(/\r$/, "", line)
            sub(/[[:space:]]*#.*/, "", line)
            sub(/[[:space:]]*$/, "", line)

            if (line ~ /^dns:[[:space:]]*$/) {
                inside=1
                next
            }

            if (inside && line ~ /^[^[:space:]]/) {
                inside=0
            }

            if (inside && line ~ /^[[:space:]]+enable:[[:space:]]*/) {
                x=line
                sub(/^[[:space:]]+enable:[[:space:]]*/, "", x)
                enabled=x
            }

            if (inside && line ~ /^[[:space:]]+listen:[[:space:]]*/) {
                x=line
                sub(/^[[:space:]]+listen:[[:space:]]*/, "", x)
                listen=x
            }
        }

        END {
            if ((enabled == "true" || enabled == "True" || enabled == "TRUE" ||
                 enabled == "yes"  || enabled == "Yes"  || enabled == "YES"  ||
                 enabled == "1"    || enabled == "on"   || enabled == "On"   ||
                 enabled == "ON") && listen != "") {
                print listen
            }
        }
        ' "$f" 2>/dev/null
    )"

    listen="$(strip_value "$listen")"
    [ -n "$listen" ] || { echo none; return; }

    p="${listen##*:}"
    p="$(printf '%s\n' "$p" | sed 's/[^0-9].*$//')"

    case "$p" in
        53) echo exclusive53 ;;
        '') echo none ;;
        *) echo "forward:$p" ;;
    esac
}

extract_yaml_section(){
    file="$1"
    section="$2"
    output="$3"

    awk -v section="$section" '
        {
            sub(/\r$/, "")
        }
        $0 ~ "^" section ":[[:space:]]*($|#)" {
            inside=1
            print
            next
        }
        inside && /^[^[:space:]#]/ {
            exit
        }
        inside {
            print
        }
    ' "$file" > "$output"
}

verify_runtime_preserves_tun(){
    source_file="$1"
    runtime_file="$2"
    source_tun="$BASE/run/tun.source.$$"
    runtime_tun="$BASE/run/tun.runtime.$$"

    extract_yaml_section "$source_file" tun "$source_tun" || return 1
    extract_yaml_section "$runtime_file" tun "$runtime_tun" || {
        rm -f "$source_tun" "$runtime_tun"
        return 1
    }

    if [ ! -s "$source_tun" ]; then
        rm -f "$source_tun" "$runtime_tun"
        fail "В config.yaml отсутствует раздел tun:"
        return 1
    fi

    if ! cmp -s "$source_tun" "$runtime_tun"; then
        warn "GoshaCrash обнаружил изменение пользовательского раздела tun:"
        diff -u "$source_tun" "$runtime_tun" 2>/dev/null || true
        rm -f "$source_tun" "$runtime_tun"
        fail "runtime.yaml отклонён: раздел tun должен сохраняться без изменений"
        return 1
    fi

    rm -f "$source_tun" "$runtime_tun"
    return 0
}

verify_runtime_requirements(){
    file="$1"

    is_true "$(yaml_section "$file" tun enable)" || {
        fail "В tun необходимо enable: true"
        return 1
    }

    is_true "$(yaml_section "$file" tun auto-route)" || {
        fail "Для маршрутизации силами Mihomo необходимо tun.auto-route: true"
        return 1
    }

    is_true "$(yaml_section "$file" tun auto-redirect)" || {
        fail "Для маршрутизации силами Mihomo необходимо tun.auto-redirect: true"
        return 1
    }

    listen="$(yaml_section "$file" dns listen)"
    [ "$listen" = "127.0.0.1:$DNS_PORT" ] || {
        fail "runtime DNS должен слушать 127.0.0.1:$DNS_PORT"
        return 1
    }

    return 0
}

render_runtime(){
    out="$1"
    [ -f "$CONFIG" ] || return 1

    cp "$CONFIG" "$out" || return 1
    sed -i 's/
$//' "$out" || return 1

    controller="$(yaml_top "$CONFIG" external-controller)"
    controller_port="${controller##*:}"
    controller_port="$(printf '%s
' "$controller_port" | sed 's/[^0-9].*$//')"
    [ -n "$controller_port" ] || controller_port=9090

    # Меняется только адрес API. Остальные корневые параметры пользователя
    # сохраняются, включая ipv6, find-process-mode и external-ui-url.
    awk -v cp="$controller_port" '
        BEGIN { seen=0 }
        /^[^[:space:]#][^:]*:[[:space:]]*/ {
            key=$0
            sub(/:.*/, "", key)
            if (key == "external-controller") {
                print "external-controller: 0.0.0.0:" cp
                seen=1
                next
            }
        }
        { print }
        END {
            if (!seen) {
                print ""
                print "external-controller: 0.0.0.0:" cp
            }
        }
    ' "$out" > "$out.controller" || return 1
    mv -f "$out.controller" "$out" || return 1

    grep -Eq '^external-ui:[[:space:]]*' "$out" ||
        printf '
external-ui: ui
' >> "$out"

    if ! grep -Eq '^dns:[[:space:]]*($|#)' "$out"; then
        cat >> "$out" <<DNS_RUNTIME

dns:
  enable: true
  listen: 127.0.0.1:$DNS_PORT
  ipv6: false
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  nameserver:
    - 1.1.1.1
    - 9.9.9.9
DNS_RUNTIME
    fi

    # На ASUS порт 53 занят dnsmasq. В существующем DNS-разделе меняется
    # исключительно listen. Остальные поля DNS сохраняются.
    awk -v p="$DNS_PORT" '
        function finish_dns() {
            if (!seen_listen)
                print "  listen: 127.0.0.1:" p
        }
        /^dns:[[:space:]]*($|#)/ {
            inside=1
            seen_listen=0
            print
            next
        }
        inside && /^[^[:space:]#]/ {
            finish_dns()
            inside=0
        }
        inside && /^[[:space:]]+listen:[[:space:]]*/ {
            print "  listen: 127.0.0.1:" p
            seen_listen=1
            next
        }
        { print }
        END {
            if (inside)
                finish_dns()
        }
    ' "$out" > "$out.dns" || return 1
    mv -f "$out.dns" "$out" || return 1

    # Критическая гарантия: tun из config.yaml попадает в runtime.yaml
    # без добавления route-exclude-address, table/rule index, strict-route
    # и без смены stack, device или auto-*.
    verify_runtime_preserves_tun "$CONFIG" "$out" || return 1
    verify_runtime_requirements "$out" || return 1
}

runtime_audit(){
    [ -f "$RUNTIME" ] || {
        fail "Нет $RUNTIME"
        return 1
    }

    verify_runtime_preserves_tun "$CONFIG" "$RUNTIME" || return 1
    verify_runtime_requirements "$RUNTIME" || return 1

    echo "runtime.yaml: OK"
    echo "Изменения GoshaCrash:"
    echo "  external-controller -> $(yaml_top "$RUNTIME" external-controller)"
    echo "  dns.listen -> $(yaml_section "$RUNTIME" dns listen)"
    echo "Раздел tun сохранён без изменений:"
    audit_tun="/tmp/goshacrash-tun-audit.$$"
    extract_yaml_section "$RUNTIME" tun "$audit_tun"
    cat "$audit_tun"
    rm -f "$audit_tun"
}

runtime_render_only(){
    ensure_dirs || return 1
    candidate="$BASE/run/runtime.render-test.yaml"
    rm -f "$candidate"
    render_runtime "$candidate" || return 1
    echo "$candidate"
}

running_pid(){
    [ -f "$PIDFILE" ] || return 1; p="$(cat "$PIDFILE" 2>/dev/null)"; [ -n "$p" ] || return 1
    kill -0 "$p" 2>/dev/null || return 1
    ps 2>/dev/null | awk -v p="$p" '$1==p{print}' | grep -q '[m]ihomo' || return 1
    echo "$p"
}

kill_mihomo(){
    if p="$(running_pid)"; then
        kill "$p" 2>/dev/null || true; n=0
        while kill -0 "$p" 2>/dev/null && [ "$n" -lt 10 ]; do sleep 1; n=$((n+1)); done
        kill -0 "$p" 2>/dev/null && kill -9 "$p" 2>/dev/null || true
    fi
    rm -f "$PIDFILE"
}

check_file(){ [ -x "$BIN" ] || { fail "Не найден $BIN"; return 1; }; "$BIN" -t -d "$BASE" -f "$1"; }

validate_runtime(){
    check_file "$RUNTIME" && return 0

    warn "runtime.yaml повреждён или не проходит проверку"
    [ -f "$PREVIOUS" ] || return 1
    check_file "$PREVIOUS" >/dev/null 2>&1 || {
        warn "runtime.previous.yaml тоже не проходит проверку"
        return 1
    }

    ensure_dirs || return 1
    stamp="$(date '+%Y%m%d-%H%M%S' 2>/dev/null)"
    [ -n "$stamp" ] || stamp="broken"
    cp "$RUNTIME" "$BASE/run/runtime.invalid-$stamp.yaml" 2>/dev/null || true
    cp "$PREVIOUS" "$RUNTIME" || return 1
    say "После сбоя восстановлен предыдущий runtime.yaml"
    check_file "$RUNTIME"
}

ensure_tun(){
    [ -c /dev/net/tun ] && return 0
    modprobe tun >/dev/null 2>&1 || true
    m="/lib/modules/$(uname -r)/kernel/drivers/net/tun.ko"; [ -c /dev/net/tun ] || { [ -f "$m" ] && insmod "$m" >/dev/null 2>&1 || true; }
    if [ ! -c /dev/net/tun ]; then mkdir -p /dev/net 2>/dev/null; mknod /dev/net/tun c 10 200 2>/dev/null; chmod 666 /dev/net/tun 2>/dev/null; fi
    [ -c /dev/net/tun ]
}

tun_enabled(){ [ -f "$RUNTIME" ] && is_true "$(yaml_section "$RUNTIME" tun enable)"; }
tun_device(){ x="$(yaml_section "$RUNTIME" tun device)"; [ -n "$x" ] || x="$TUN_DEVICE"; echo "$x"; }

wait_port(){
    p="$1"; n=0
    while [ "$n" -lt 15 ]; do netstat -ln 2>/dev/null | grep -Eq "[:.]$p[[:space:]]" && return 0; sleep 1; n=$((n+1)); done
    return 1
}

wait_tun(){
    tun_enabled || return 0; d="$(tun_device)"; n=0
    while [ "$n" -lt 15 ]; do ip link show "$d" >/dev/null 2>&1 && return 0; ifconfig "$d" >/dev/null 2>&1 && return 0; sleep 1; n=$((n+1)); done
    return 1
}

cleanup_legacy_network(){
    # Remove only rules created by older GoshaCrash builds.
    # No new routing/firewall rules are created here.
    for i in $(lan_ifaces); do
        while iptables -t mangle -D PREROUTING -i "$i" -j "$LEGACY_MANGLE_CHAIN" 2>/dev/null; do :; done
        while iptables -t nat -D PREROUTING -i "$i" -p tcp -j "$LEGACY_REDIR_CHAIN" 2>/dev/null; do :; done
        while iptables -t nat -D PREROUTING -i "$i" -p udp --dport 53 -j "$LEGACY_DNS_CHAIN" 2>/dev/null; do :; done
        while iptables -t nat -D PREROUTING -i "$i" -p tcp --dport 53 -j "$LEGACY_DNS_CHAIN" 2>/dev/null; do :; done
    done

    while iptables -t mangle -D OUTPUT -j "$LEGACY_ROUTER_TUN_CHAIN" 2>/dev/null; do :; done
    while iptables -t nat -D OUTPUT -p tcp -j "$LEGACY_ROUTER_TCP_CHAIN" 2>/dev/null; do :; done
    while iptables -t nat -D OUTPUT -p udp --dport 53 -j "$LEGACY_ROUTER_DNS_CHAIN" 2>/dev/null; do :; done
    while iptables -t nat -D OUTPUT -p tcp --dport 53 -j "$LEGACY_ROUTER_DNS_CHAIN" 2>/dev/null; do :; done
    while iptables -D FORWARD -j "$LEGACY_FILTER_CHAIN" 2>/dev/null; do :; done

    for c in "$LEGACY_MANGLE_CHAIN" "$LEGACY_ROUTER_TUN_CHAIN"; do
        iptables -t mangle -F "$c" 2>/dev/null || true
        iptables -t mangle -X "$c" 2>/dev/null || true
    done
    for c in "$LEGACY_DNS_CHAIN" "$LEGACY_REDIR_CHAIN" "$LEGACY_ROUTER_TCP_CHAIN" "$LEGACY_ROUTER_DNS_CHAIN"; do
        iptables -t nat -F "$c" 2>/dev/null || true
        iptables -t nat -X "$c" 2>/dev/null || true
    done
    iptables -F "$LEGACY_FILTER_CHAIN" 2>/dev/null || true
    iptables -X "$LEGACY_FILTER_CHAIN" 2>/dev/null || true

    while ip rule del fwmark 0x2333 table 2022 pref 10010 2>/dev/null; do :; done
    while ip rule del fwmark 0x2333 table 2022 2>/dev/null; do :; done
    ip route flush table 2022 2>/dev/null || true
    ip route flush cache 2>/dev/null || true
}

start_mihomo(){
    if p="$(running_pid)"; then
        [ "${GOSHACRASH_WATCHDOG_INTERNAL:-0}" = 1 ] || watchdog_start || true
        echo "Mihomo уже запущен, PID=$p"
        return 0
    fi

    [ -f "$RUNTIME" ] || {
        fail "Сначала выполни: goshacrash apply"
        return 1
    }
    ensure_tun || {
        fail "Нет /dev/net/tun"
        return 1
    }
    validate_runtime || return 1

    cleanup_legacy_network
    ensure_dirs || return 1
    rm -f "$PIDFILE"
    [ -f "$LOGFILE" ] && [ "$(wc -c < "$LOGFILE" 2>/dev/null)" -gt 1048576 ] 2>/dev/null &&
        mv -f "$LOGFILE" "$LOGFILE.previous"

    GOGC="${GOGC:-50}" "$BIN" -d "$BASE" -f "$RUNTIME" >> "$LOGFILE" 2>&1 &
    p=$!
    echo "$p" > "$PIDFILE"
    sleep 2

    running_pid >/dev/null 2>&1 || {
        fail "Mihomo завершился"
        tail -n 100 "$LOGFILE"
        return 1
    }

    wait_port "$DNS_PORT" || {
        kill_mihomo
        fail "Mihomo DNS не слушает порт $DNS_PORT"
        tail -n 100 "$LOGFILE"
        return 1
    }

    wait_tun || {
        kill_mihomo
        fail "Mihomo не создал TUN-интерфейс"
        tail -n 100 "$LOGFILE"
        return 1
    }

    echo "Mihomo запущен, PID=$(cat "$PIDFILE" 2>/dev/null)"
    echo "[GoshaCrash] Маршрутизацией управляет Mihomo: auto-route=true, auto-redirect=true"
    [ "${GOSHACRASH_WATCHDOG_INTERNAL:-0}" = 1 ] || watchdog_start || true
}

stop_mihomo(){
    [ "${GOSHACRASH_WATCHDOG_INTERNAL:-0}" = 1 ] || watchdog_stop
    kill_mihomo
    cleanup_legacy_network
    echo "Mihomo остановлен"
}

backup_config(){
    ensure_dirs || return 1; [ -f "$CONFIG" ] || return 1
    s="$(date '+%Y%m%d-%H%M%S' 2>/dev/null)"; [ -n "$s" ] || s=backup
    f="$BACKUPS/config-$s.yaml"; cp "$CONFIG" "$f" || return 1; echo "$f"
}

install_hooks(){
    opt="$USB_MOUNT/asusware.arm"; [ -d "$opt" ] || { fail "Не найден Download Master: $opt"; return 1; }
    init="$opt/etc/init.d/S99goshacrash"; ctl="$opt/lib/ipkg/info/goshacrash.control"
    mkdir -p "$(dirname "$init")" "$(dirname "$ctl")" "$JFFS_BASE" || return 1
    echo "$BASE" > "$JFFS_BASE_FILE" || return 1
    cat > "$init" <<HOOK
#!/bin/sh
BASE_FILE="$JFFS_BASE_FILE"
BASE="$BASE"
[ -f "\$BASE_FILE" ] && { x="\$(cat "\$BASE_FILE" 2>/dev/null)"; [ -n "\$x" ] && BASE="\$x"; }
CTL="\$BASE/goshacrash"
case "\$1" in
 start) sleep 5; [ -x "\$CTL" ] && GOSHACRASH_BASE="\$BASE" "\$CTL" boot;;
 restart|force-reload) [ -x "\$CTL" ] && GOSHACRASH_BASE="\$BASE" "\$CTL" restart;;
 stop) [ -x "\$CTL" ] && GOSHACRASH_BASE="\$BASE" "\$CTL" stop;;
 firewall-start|firewall-restart) [ -x "\$CTL" ] && GOSHACRASH_BASE="\$BASE" "\$CTL" firewall-reload;;
 *) exit 0;;
esac
exit 0
HOOK
    chmod 755 "$init" || return 1
    cat > "$ctl" <<CONTROL
Package: goshacrash
Architecture: arm
Priority: optional
Section: net
Version: $VERSION
Maintainer: GoshaCrash
Source: local
Description: Mihomo and Zashboard controller for stock ASUSWRT
Depends:
Suggests:
Conflicts:
Enabled: yes
CONTROL
    mkdir -p /opt/lib/ipkg/info 2>/dev/null || true; cp "$ctl" /opt/lib/ipkg/info/goshacrash.control 2>/dev/null || true
    say "Автозапуск установлен: $init"
}

uninstall_hooks(){
    stop_mihomo >/dev/null 2>&1 || true; opt="$USB_MOUNT/asusware.arm"
    rm -f "$opt/etc/init.d/S99goshacrash" "$opt/lib/ipkg/info/goshacrash.control" /opt/lib/ipkg/info/goshacrash.control
    rm -rf "$JFFS_BASE"; say "Автозапуск удалён"
}

apply_config(){
    [ -f "$CONFIG" ] || { fail "Не найден $CONFIG"; return 1; }; ensure_dirs || return 1
    b="$(backup_config)" || return 1; say "Резервная копия: $b"
    cand="$BASE/run/runtime.candidate.yaml"; rm -f "$cand"; render_runtime "$cand" || return 1
    [ -f "$RUNTIME" ] && cp "$RUNTIME" "$PREVIOUS" 2>/dev/null || rm -f "$PREVIOUS"
    stop_mihomo >/dev/null 2>&1 || true
    say "Проверяю runtime.yaml"; check_file "$cand" || { rm -f "$cand"; [ -f "$PREVIOUS" ] && { cp "$PREVIOUS" "$RUNTIME"; start_mihomo >/dev/null 2>&1 || true; }; return 1; }
    mv -f "$cand" "$RUNTIME" || return 1; install_hooks || return 1
    start_mihomo || { fail "Новый конфиг не запустился"; [ -f "$PREVIOUS" ] && { cp "$PREVIOUS" "$RUNTIME"; start_mihomo >/dev/null 2>&1 || true; }; return 1; }
    say "Конфиг применён"; status
}

check_config(){ ensure_dirs || return 1; t="$BASE/run/check.yaml"; render_runtime "$t" || return 1; check_file "$t"; r=$?; rm -f "$t"; return "$r"; }

boot_service(){
    n=0; while [ ! -x "$BIN" ] && [ "$n" -lt 30 ]; do sleep 2; n=$((n+1)); done
    [ -x "$BIN" ] || return 1; [ -f "$RUNTIME" ] || return 0
    start_mihomo
}

prepend_path(){
    d="$1"
    [ -n "$d" ] || return 0
    case ":$PATH:" in
        *":$d:"*) ;;
        *) PATH="$d:$PATH"; export PATH;;
    esac
}

find_nano(){
    if have nano; then
        which nano
        return 0
    fi

    for p in \
        /opt/bin/nano \
        /tmp/opt/bin/nano \
        "$USB_MOUNT/asusware.arm/bin/nano" \
        "$USB_MOUNT/asusware.arm/opt/bin/nano" \
        "$USB_MOUNT/asusware.arm/usr/bin/nano"; do
        if [ -x "$p" ]; then
            prepend_path "${p%/*}"
            printf '%s\n' "$p"
            return 0
        fi
    done

    if [ -d "$USB_MOUNT/asusware.arm" ]; then
        p="$(find "$USB_MOUNT/asusware.arm" -type f -name nano 2>/dev/null | head -n 1)"
        if [ -n "$p" ] && [ -x "$p" ]; then
            prepend_path "${p%/*}"
            printf '%s\n' "$p"
            return 0
        fi
    fi

    return 1
}


find_editor(){
    requested="${EDITOR:-}"
    if [ -n "$requested" ]; then
        case "$requested" in
            */*) [ -x "$requested" ] && { printf '%s\n' "$requested"; return 0; };;
            *) have "$requested" && { which "$requested"; return 0; };;
        esac
    fi

    nano_bin="$(find_nano)"
    [ -n "$nano_bin" ] && [ -x "$nano_bin" ] && { printf '%s\n' "$nano_bin"; return 0; }

    for x in mcedit vi; do
        have "$x" && { which "$x"; return 0; }
    done
    return 1
}

edit_config(){
    write_default_config || return 1
    editor_bin="$(find_editor)" || {
        fail "Текстовый редактор не найден. Передай config.yaml через scp или установи редактор вручную."
        return 1
    }
    say "Редактор: $editor_bin"
    "$editor_bin" "$CONFIG"
}

restore_config(){
    f="${1:-}"; [ -n "$f" ] || f="$(ls -1t "$BACKUPS"/config-*.yaml 2>/dev/null | head -n 1)"
    [ -f "$f" ] || { fail "Резервная копия не найдена"; return 1; }; cp "$f" "$CONFIG" || return 1; apply_config
}

install_all(){
    ensure_dirs || return 1
    write_default_config || return 1
    install_core || { fail "Установка Mihomo не завершена"; return 1; }
    install_ui || { fail "Установка Zashboard не завершена"; return 1; }
    install_hooks || return 1
    apply_config
}
update_all(){
    stop_mihomo >/dev/null 2>&1 || true
    install_core || return 1
    install_ui || return 1
    apply_config
}

# -----------------------------------------------------------------------------
# Router runtime defaults.
# Mihomo itself creates TUN routes and transparent-redirection rules through
# auto-route/auto-redirect. GoshaCrash only generates runtime.yaml, starts the
# service, removes rules left by older builds and runs the WAN watchdog.
# -----------------------------------------------------------------------------

write_default_config(){
    [ -f "$CONFIG" ] && return 0
    ensure_dirs || return 1
    router_ip="$(lan_ip)"
    cat > "$CONFIG" <<CFG
# Личный config.yaml. Обновление GoshaCrash этот файл не заменяет.
# На роутере dnsmasq слушает :53, а GoshaCrash меняет DNS listener только
# в runtime.yaml на 127.0.0.1:1053.

mixed-port: 7892
allow-lan: true
bind-address: "*"
mode: rule
log-level: info
ipv6: false
find-process-mode: off

external-controller: 0.0.0.0:9090
secret: "CHANGE_ME"
external-ui: ui

profile:
  store-selected: true
  store-fake-ip: true

hosts:
  "www.asusrouter.com": $router_ip
  "router.asus.com": $router_ip

dns:
  enable: true
  listen: 127.0.0.1:1053
  ipv6: false
  prefer-h3: false
  use-hosts: true
  use-system-hosts: false
  respect-rules: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-filter:
    - "+.lan"
    - "+.local"
    - "+.arpa"
    - "localhost"

  # DNS только для автоматически созданного тестового конфига.
  default-nameserver:
    - 1.1.1.1
    - 9.9.9.9
  proxy-server-nameserver:
    - 1.1.1.1
    - 9.9.9.9

  nameserver:
    - "https://1.1.1.1/dns-query#GLOBAL-PROXY"
    - "https://8.8.8.8/dns-query#GLOBAL-PROXY"
  direct-nameserver:
    - 1.1.1.1
    - 9.9.9.9

tun:
  enable: true
  stack: mixed
  device: tun
  dns-hijack:
    - "any:53"
    - "tcp://any:53"
  auto-route: true
  auto-redirect: true
  auto-detect-interface: true

proxies: []

proxy-groups:
  - name: GLOBAL-PROXY
    type: select
    proxies:
      - DIRECT

rules:
  - MATCH,DIRECT
CFG
    chmod 600 "$CONFIG" 2>/dev/null || true
    say "Создан $CONFIG"
}

watchdog_pid(){
    [ -f "$WATCHDOG_PIDFILE" ] || return 1
    p="$(cat "$WATCHDOG_PIDFILE" 2>/dev/null)"
    case "$p" in ''|*[!0-9]*) return 1;; esac
    kill -0 "$p" 2>/dev/null || return 1

    if [ -r "/proc/$p/cmdline" ]; then
        tr '\000' ' ' < "/proc/$p/cmdline" 2>/dev/null |
            grep -q 'watchdog-loop' || return 1
    fi

    printf '%s\n' "$p"
}

watchdog_log(){
    ensure_dirs >/dev/null 2>&1 || true

    if [ -f "$WATCHDOG_LOG" ]; then
        size="$(wc -c < "$WATCHDOG_LOG" 2>/dev/null)"
        case "$size" in ''|*[!0-9]*) size=0;; esac
        [ "$size" -le 262144 ] ||
            mv -f "$WATCHDOG_LOG" "$WATCHDOG_LOG.previous"
    fi

    stamp="$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null)"
    [ -n "$stamp" ] || stamp="unknown-time"
    printf '%s %s\n' "$stamp" "$*" >> "$WATCHDOG_LOG"
}

watchdog_stop(){
    if p="$(watchdog_pid)"; then
        kill "$p" 2>/dev/null || true
        n=0
        while kill -0 "$p" 2>/dev/null && [ "$n" -lt 5 ]; do
            sleep 1
            n=$((n + 1))
        done
        kill -0 "$p" 2>/dev/null && kill -9 "$p" 2>/dev/null || true
    fi
    rm -f "$WATCHDOG_PIDFILE"
}

watchdog_start(){
    watchdog_pid >/dev/null 2>&1 && return 0
    ensure_dirs || return 1
    [ -x "$BASE/goshacrash" ] || return 1

    if have nohup; then
        GOSHACRASH_BASE="$BASE" nohup "$BASE/goshacrash" watchdog-loop \
            </dev/null >> "$WATCHDOG_LOG" 2>&1 &
    else
        GOSHACRASH_BASE="$BASE" "$BASE/goshacrash" watchdog-loop \
            </dev/null >> "$WATCHDOG_LOG" 2>&1 &
    fi

    p=$!
    echo "$p" > "$WATCHDOG_PIDFILE"
    sleep 1
    kill -0 "$p" 2>/dev/null || {
        rm -f "$WATCHDOG_PIDFILE"
        warn "WAN watchdog не запустился"
        return 1
    }

    say "WAN watchdog запущен, PID=$p"
}

watchdog_wan_route_present(){
    if ip route show 2>/dev/null | awk -v d="$TUN_DEVICE" '
        $1 == "default" && $0 !~ ("dev " d "([[:space:]]|$)") {found=1}
        END {exit(found ? 0 : 1)}
    '; then
        return 0
    fi

    route -n 2>/dev/null | awk -v d="$TUN_DEVICE" '
        $1 == "0.0.0.0" && $8 != d {found=1}
        END {exit(found ? 0 : 1)}
    '
}

watchdog_probe_url(){
    url="$1"
    tmp="/tmp/goshacrash-watchdog.$$"
    rm -f "$tmp"

    if [ -x /usr/sbin/wget ]; then
        HOME=/tmp /usr/sbin/wget -T 12 -t 1 --no-check-certificate \
            -O "$tmp" "$url" >/dev/null 2>&1
        rc=$?
    elif have wget; then
        HOME=/tmp "$(which wget)" -T 12 -t 1 --no-check-certificate \
            -O "$tmp" "$url" >/dev/null 2>&1
        rc=$?
    elif have curl; then
        HOME=/tmp "$(which curl)" -4 -k -f -L \
            --connect-timeout 8 --max-time 15 -o "$tmp" "$url" >/dev/null 2>&1
        rc=$?
    else
        rc=1
    fi

    rm -f "$tmp"
    return "$rc"
}

watchdog_internet_ok(){
    for url in $WATCHDOG_URLS; do
        watchdog_probe_url "$url" && return 0
    done
    return 1
}

watchdog_local_ok(){
    running_pid >/dev/null 2>&1 || return 1
    netstat -ln 2>/dev/null | grep -Eq "[:.]$DNS_PORT[[:space:]]" || return 1

    d="$(tun_device)"
    ip link show "$d" >/dev/null 2>&1 ||
        ifconfig "$d" >/dev/null 2>&1 || return 1

    # Номера таблиц и правил выбирает Mihomo. Фактическую работоспособность
    # маршрутизации проверяет end-to-end HTTPS probe.
    return 0
}

watchdog_now(){
    now="$(date '+%s' 2>/dev/null)"
    case "$now" in ''|*[!0-9]*) now=0;; esac
    printf '%s\n' "$now"
}

watchdog_soft_restart(){
    watchdog_log "Мягкий перезапуск Mihomo"
    GOSHACRASH_WATCHDOG_INTERNAL=1
    export GOSHACRASH_WATCHDOG_INTERNAL
    stop_mihomo >/dev/null 2>&1 || true
    sleep 2
    start_mihomo >/dev/null 2>&1
    rc=$?
    unset GOSHACRASH_WATCHDOG_INTERNAL
    return "$rc"
}

watchdog_loop(){
    cleanup_watchdog(){
        saved="$(cat "$WATCHDOG_PIDFILE" 2>/dev/null)"
        [ "$saved" = "$$" ] && rm -f "$WATCHDOG_PIDFILE"
    }

    trap 'cleanup_watchdog; exit 0' TERM INT HUP
    trap 'cleanup_watchdog' EXIT
    echo "$$" > "$WATCHDOG_PIDFILE"

    watchdog_log "Watchdog запущен: interval=${WATCHDOG_INTERVAL}s threshold=$WATCHDOG_FAIL_THRESHOLD cooldown=${WATCHDOG_ACTION_COOLDOWN}s"

    slept=0
    while [ "$slept" -lt "$WATCHDOG_BOOT_GRACE" ]; do
        sleep 5
        slept=$((slept + 5))
    done

    state=boot
    failures=0
    last_action=0

    while :; do
        if ! watchdog_wan_route_present; then
            if [ "$state" != down ]; then
                watchdog_log "WAN потерян: основной default route отсутствует; сервисы оставлены запущенными"
            fi
            state=down
            failures=0
            sleep "$WATCHDOG_INTERVAL"
            continue
        fi

        if [ "$state" = down ]; then
            watchdog_log "WAN-маршрут вернулся"
        fi

        if ! running_pid >/dev/null 2>&1; then
            now="$(watchdog_now)"
            elapsed=$((now - last_action))
            if [ "$last_action" -eq 0 ] ||
               [ "$elapsed" -ge "$WATCHDOG_ACTION_COOLDOWN" ]; then
                watchdog_log "Mihomo не запущен при доступном WAN; выполняется запуск"
                GOSHACRASH_WATCHDOG_INTERNAL=1
                export GOSHACRASH_WATCHDOG_INTERNAL
                start_mihomo >/dev/null 2>&1
                rc=$?
                unset GOSHACRASH_WATCHDOG_INTERNAL
                last_action="$now"
                [ "$rc" -eq 0 ] ||
                    watchdog_log "Запустить Mihomo не удалось"
            fi
        fi

        if running_pid >/dev/null 2>&1 && ! watchdog_local_ok; then
            watchdog_log "TUN или auto-route Mihomo повреждены; выполняется мягкий перезапуск Mihomo"
            watchdog_soft_restart || true
            sleep 8
        fi

        if ! running_pid >/dev/null 2>&1; then
            state=degraded
            failures=0
            sleep "$WATCHDOG_INTERVAL"
            continue
        fi

        if watchdog_internet_ok; then
            if [ "$state" != up ]; then
                watchdog_log "Интернет доступен через текущую схему Mihomo"
            fi
            state=up
            failures=0
            sleep "$WATCHDOG_INTERVAL"
            continue
        fi

        failures=$((failures + 1))
        if [ "$failures" -eq 1 ]; then
            watchdog_log "WAN-маршрут есть, но контрольный интернет-запрос не проходит"
        fi
        state=degraded

        if [ "$failures" -ge "$WATCHDOG_FAIL_THRESHOLD" ]; then
            now="$(watchdog_now)"
            elapsed=$((now - last_action))

            if [ "$last_action" -eq 0 ] ||
               [ "$elapsed" -ge "$WATCHDOG_ACTION_COOLDOWN" ]; then
                watchdog_log "Порог ошибок достигнут; Mihomo будет перезапущен для пересоздания auto-route/auto-redirect"
                watchdog_soft_restart || true
                sleep 8

                if watchdog_internet_ok; then
                    watchdog_log "Связь восстановлена после мягкого перезапуска Mihomo"
                    state=up
                else
                    watchdog_log "Связь не восстановлена; следующий restart будет не раньше cooldown"
                    state=degraded
                fi

                failures=0
                last_action="$now"
            fi
        fi

        sleep "$WATCHDOG_INTERVAL"
    done
}

watchdog_status(){
    if p="$(watchdog_pid)"; then
        echo "WAN watchdog: работает, PID=$p"
    else
        echo "WAN watchdog: не запущен"
    fi

    echo "Интервал: ${WATCHDOG_INTERVAL}s; порог: $WATCHDOG_FAIL_THRESHOLD; cooldown: ${WATCHDOG_ACTION_COOLDOWN}s"
    if [ -f "$WATCHDOG_LOG" ]; then
        echo "Последние события:"
        tail -n 12 "$WATCHDOG_LOG" 2>/dev/null
    fi
}

dns_status(){
    dnsmasq_ok=no
    mihomo_ok=no
    netstat -ln 2>/dev/null | grep -Eq '[:.]53[[:space:]]' && dnsmasq_ok=yes
    netstat -ln 2>/dev/null | grep -Eq "[:.]$DNS_PORT[[:space:]]" && mihomo_ok=yes
    echo "dnsmasq:53=$dnsmasq_ok; Mihomo DNS:$DNS_PORT=$mihomo_ok; hijack=Mihomo TUN"
}

firewall_reload(){
    running_pid >/dev/null 2>&1 || return 0
    say "ASUSWRT перезапустил firewall; перезапускаю Mihomo, чтобы он заново создал auto-route/auto-redirect"
    GOSHACRASH_WATCHDOG_INTERNAL=1
    export GOSHACRASH_WATCHDOG_INTERNAL
    kill_mihomo
    sleep 2
    start_mihomo
    rc=$?
    unset GOSHACRASH_WATCHDOG_INTERNAL
    return "$rc"
}

status(){
    if p="$(running_pid)"; then
        echo "Mihomo: работает, PID=$p"
    else
        echo "Mihomo: не запущен"
    fi
    echo "GoshaCrash: $VERSION"
    echo "Режим маршрутизации: управляет Mihomo"
    echo "BASE: $BASE"
    echo "DNS: $(dns_status)"

    d="$(tun_device)"
    if ip link show "$d" >/dev/null 2>&1 || ifconfig "$d" >/dev/null 2>&1; then
        echo "TUN: $d работает"
    else
        echo "TUN: $d не найден"
    fi

    echo "Mihomo TUN: stack=$(yaml_section "$RUNTIME" tun stack)"
    echo "Mihomo TUN: auto-route=$(yaml_section "$RUNTIME" tun auto-route)"
    echo "Mihomo TUN: auto-redirect=$(yaml_section "$RUNTIME" tun auto-redirect)"
    echo "Mihomo TUN: auto-detect-interface=$(yaml_section "$RUNTIME" tun auto-detect-interface)"

    if p="$(watchdog_pid)"; then
        echo "WAN watchdog: работает, PID=$p"
    else
        echo "WAN watchdog: не запущен"
    fi

    c="$(yaml_top "$RUNTIME" external-controller)"
    [ -n "$c" ] || c=0.0.0.0:9090
    p="${c##*:}"
    p="$(echo "$p" | sed 's/[^0-9].*$//')"
    [ -n "$p" ] || p=9090
    echo "Zashboard: http://$(lan_ip):$p/ui/"
    s="$(yaml_top "$RUNTIME" secret)"
    [ -n "$s" ] && echo "API secret: $s"
}

doctor(){
    echo "=== GoshaCrash doctor ==="
    echo "BASE=$BASE"
    echo "USB=$USB_MOUNT"
    echo "ARCH=$(uname -m)"
    echo "LAN=$(lan_ifaces)"
    echo "IP=$(lan_ip)"
    echo

    [ -x "$BIN" ] && "$BIN" -v || echo "Mihomo: NOT FOUND"
    [ -c /dev/net/tun ] && echo "/dev/net/tun: OK" || echo "/dev/net/tun: NOT FOUND"
    echo
    status
    echo

    echo "=== runtime tun ==="
    awk '
      /^tun:[[:space:]]*($|#)/ {inside=1}
      inside {print}
      inside && NR>1 && /^[^[:space:]#]/ && $0 !~ /^tun:/ {exit}
    ' "$RUNTIME" 2>/dev/null
    echo

    echo "=== routes and rules created by Mihomo ==="
    ip rule show 2>/dev/null || true
    echo "--- main table ---"
    ip route show 2>/dev/null || true
    echo "--- table 2022, only if Mihomo selected it ---"
    ip route show table 2022 2>/dev/null || true
    echo

    echo "=== firewall objects visible after Mihomo start ==="
    iptables -t nat -S 2>/dev/null | grep -Ei 'mihomo|clash|meta|redirect|tproxy' || true
    iptables -t mangle -S 2>/dev/null | grep -Ei 'mihomo|clash|meta|mark|tproxy' || true
    echo

    echo "=== old GoshaCrash rules must be absent ==="
    iptables-save 2>/dev/null | grep 'GOSHACRASH_' || true
    echo

    echo "=== log ==="
    tail -n 100 "$LOGFILE" 2>/dev/null || true
}

pause_menu(){ printf '\nНажми Enter для продолжения...'; read _dummy; }

menu(){
    while :; do
        printf '\033[2J\033[H'
        echo '========================================'
        echo "      GoshaCrash $VERSION"
        echo '========================================'
        if p="$(running_pid)"; then
            echo "Mihomo: работает, PID=$p"
        else
            echo "Mihomo: не запущен"
        fi
        if p="$(watchdog_pid)"; then
            echo "Watchdog: работает, PID=$p"
        else
            echo "Watchdog: не запущен"
        fi
        echo
        echo '1) Запустить Mihomo'
        echo '2) Остановить Mihomo'
        echo '3) Перезапустить Mihomo'
        echo '4) Редактировать config.yaml и применить'
        echo '5) Применить config.yaml'
        echo '10) Показать адрес Zashboard'
        echo '11) Обновить Mihomo и Zashboard'
        echo '0) Выход'
        echo '========================================'
        printf 'Выбери пункт: '
        read choice
        case "$choice" in
            1) start_mihomo;;
            2) stop_mihomo;;
            3) stop_mihomo; start_mihomo;;
            4) edit_config && apply_config;;
            5) apply_config;;
            10) c="$(yaml_top "$RUNTIME" external-controller)"; [ -n "$c" ] || c=0.0.0.0:9090; p="${c##*:}"; p="$(echo "$p"|sed 's/[^0-9].*$//')"; echo "http://$(lan_ip):${p:-9090}/ui/";;
            11) update_all;;
            0) return 0;;
            *) echo 'Неизвестный пункт';;
        esac
        pause_menu
    done
}

usage(){ cat <<'USAGE'
GoshaCrash 0.9.0-rc1

Управление:
  goshacrash                 открыть меню
  goshacrash start           запустить Mihomo и watchdog
  goshacrash stop            остановить Mihomo и watchdog
  goshacrash restart         перезапустить Mihomo
  goshacrash edit            изменить config.yaml и применить
  goshacrash apply           применить config.yaml
  goshacrash status          показать состояние
  goshacrash ui              показать адрес Zashboard
  goshacrash update          обновить Mihomo и Zashboard
  goshacrash watchdog-status состояние watchdog
  goshacrash runtime-audit   проверить неизменность tun
USAGE
}

ensure_dirs >/dev/null 2>&1 || true
case "${1:-menu}" in
 menu) menu;;
 start) start_mihomo;;
 stop) stop_mihomo;;
 restart) stop_mihomo; start_mihomo;;
 edit|setup) edit_config && apply_config;;
 apply) apply_config;;
 status) status;;
 ui) c="$(yaml_top "$RUNTIME" external-controller)"; [ -n "$c" ] || c=0.0.0.0:9090; p="${c##*:}"; p="$(echo "$p"|sed 's/[^0-9].*$//')"; echo "http://$(lan_ip):${p:-9090}/ui/";;
 update) update_all;;
 watchdog-status) watchdog_status;;
 runtime-audit) runtime_audit;;
 runtime-render) runtime_render_only;;
 help|-h|--help) usage;;

 # Служебные команды — не показываются в пользовательском меню.
 install) install_all;;
 check) check_config;;
 doctor) doctor;;
 logs) tail -n "${2:-100}" "$LOGFILE" 2>/dev/null || true;;
 backup) backup_config;;
 restore) restore_config "${2:-}";;
 install-hooks) install_hooks;;
 uninstall-hooks) uninstall_hooks;;
 boot) boot_service;;
 firewall-reload) firewall_reload;;
 watchdog-loop) watchdog_loop;;
 version) echo "$VERSION";;

 *) usage; exit 1;;
esac
