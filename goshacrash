#!/bin/sh

SCRIPT_DIR="$(CDPATH= cd "$(dirname "$0")" 2>/dev/null && pwd)"
[ -n "$SCRIPT_DIR" ] || {
    echo "Не удалось определить каталог GoshaCrash" >&2
    exit 1
}

BASE="$SCRIPT_DIR"
BIN="$BASE/bin/mihomo"
CONFIG="$BASE/config.yaml"
PID_FILE="$BASE/run/mihomo.pid"
LOG_FILE="$BASE/logs/mihomo.log"

USB_MOUNT="$(dirname "$BASE")"
PATH="/opt/bin:/opt/sbin:$USB_MOUNT/asusware.arm/bin:$USB_MOUNT/asusware.arm/sbin:/usr/sbin:/usr/bin:/sbin:/bin"
export PATH

get_pid() {
    [ -f "$PID_FILE" ] || return 1
    pid="$(cat "$PID_FILE" 2>/dev/null)"
    [ -n "$pid" ] || return 1
    kill -0 "$pid" 2>/dev/null || return 1
    printf '%s\n' "$pid"
}

check_config() {
    [ -x "$BIN" ] || {
        echo "Mihomo не найден: $BIN" >&2
        return 1
    }

    [ -f "$CONFIG" ] || {
        echo "Конфиг не найден: $CONFIG" >&2
        return 1
    }

    "$BIN" -t -d "$BASE" -f "$CONFIG"
}

start_mihomo() {
    if pid="$(get_pid)"; then
        echo "Mihomo уже запущен, PID=$pid"
        return 0
    fi

    mkdir -p "$BASE/run" "$BASE/logs"
    rm -f "$PID_FILE"

    check_config || return 1

    "$BIN" -d "$BASE" -f "$CONFIG" >> "$LOG_FILE" 2>&1 &
    pid=$!
    printf '%s\n' "$pid" > "$PID_FILE"

    sleep 2

    if running_pid="$(get_pid)"; then
        echo "Mihomo запущен, PID=$running_pid"
        return 0
    fi

    echo "Mihomo завершился при запуске" >&2
    rm -f "$PID_FILE"
    tail -n 40 "$LOG_FILE" 2>/dev/null
    return 1
}

stop_mihomo() {
    if pid="$(get_pid)"; then
        kill "$pid" 2>/dev/null || true

        counter=0
        while kill -0 "$pid" 2>/dev/null && [ "$counter" -lt 10 ]; do
            sleep 1
            counter=$((counter + 1))
        done

        if kill -0 "$pid" 2>/dev/null; then
            kill -9 "$pid" 2>/dev/null || true
        fi

        rm -f "$PID_FILE"
        echo "Mihomo остановлен"
        return 0
    fi

    rm -f "$PID_FILE"
    echo "Mihomo не запущен"
}

edit_config() {
    for editor in /opt/bin/nano "$USB_MOUNT/asusware.arm/bin/nano" /usr/bin/nano /bin/nano; do
        if [ -x "$editor" ]; then
            exec "$editor" "$CONFIG"
        fi
    done

    echo "nano не найден, открываю vi"
    exec vi "$CONFIG"
}

show_ui() {
    lan_ip="$(nvram get lan_ipaddr 2>/dev/null)"
    [ -n "$lan_ip" ] || lan_ip="127.0.0.1"
    secret="$(sed -n 's/^[[:space:]]*secret:[[:space:]]*["'"']\{0,1\}\([^"'"']*\)["'"']\{0,1\}[[:space:]]*$/\1/p' "$CONFIG" | head -n 1)"

    echo "Zashboard: http://$lan_ip:9090/ui/"
    [ -n "$secret" ] && echo "API secret: $secret"
}

case "${1:-}" in
    start)
        start_mihomo
        ;;
    stop)
        stop_mihomo
        ;;
    restart|reload)
        stop_mihomo
        start_mihomo
        ;;
    status)
        if pid="$(get_pid)"; then
            echo "Mihomo работает, PID=$pid"
        else
            echo "Mihomo остановлен"
            exit 1
        fi
        ;;
    check)
        check_config
        ;;
    edit)
        edit_config
        ;;
    logs)
        lines="${2:-80}"
        tail -n "$lines" "$LOG_FILE" 2>/dev/null || echo "Лог пока пуст"
        ;;
    version)
        "$BIN" -v
        ;;
    ui)
        show_ui
        ;;
    *)
        cat <<EOF
GoshaCrash — управление Mihomo

Использование: $0 COMMAND

Команды:
  start       запустить Mihomo
  stop        остановить Mihomo
  restart     перезапустить Mihomo
  reload      проверить конфиг и перезапустить
  status      показать состояние
  check       проверить config.yaml
  edit        открыть config.yaml
  logs [N]    показать последние N строк лога
  version     показать версию Mihomo
  ui          показать адрес Zashboard
EOF
        ;;
esac
