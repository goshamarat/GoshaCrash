#!/bin/sh

APP_NAME="GoshaCrash"
APP_BIN="goshacrash"
APP_VERSION="0.5.0-user"

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" 2>/dev/null && pwd)"

GC_HOME="${GC_HOME:-$HOME/.goshacrash}"

BIN_DIR="$GC_HOME/bin"
CONFIG_DIR="$GC_HOME/config"
UI_DIR="$GC_HOME/ui"
LOG_DIR="$GC_HOME/logs"
RUN_DIR="$GC_HOME/run"
TMP_DIR="$GC_HOME/tmp"
DATA_DIR="$GC_HOME/data"
CUSTOM_DIR="$GC_HOME/custom"
BACKUP_DIR="$GC_HOME/backups"

TEMPLATE_DIR="$SCRIPT_DIR/templates"

ENV_FILE="$CUSTOM_DIR/env.conf"
DNS_FILE="$CUSTOM_DIR/dns.yaml"
PROFILE_FILE="$CUSTOM_DIR/profile.yaml"
FINAL_CONFIG="$CONFIG_DIR/config.yaml"

LANG_FILE="$DATA_DIR/lang"

MIHOMO_BIN="$BIN_DIR/mihomo"
MIHOMO_PID_FILE="$RUN_DIR/mihomo.pid"
MIHOMO_LOG_FILE="$LOG_DIR/mihomo.log"

MIHOMO_MIXED_PORT="${MIHOMO_MIXED_PORT:-7890}"
MIHOMO_API_HOST="${MIHOMO_API_HOST:-127.0.0.1}"
MIHOMO_API_PORT="${MIHOMO_API_PORT:-9090}"
MIHOMO_DNS_HOST="${MIHOMO_DNS_HOST:-127.0.0.1}"
MIHOMO_DNS_PORT="${MIHOMO_DNS_PORT:-1053}"

MIHOMO_ALLOW_LAN="${MIHOMO_ALLOW_LAN:-false}"
MIHOMO_BIND_ADDRESS="${MIHOMO_BIND_ADDRESS:-127.0.0.1}"
MIHOMO_SECRET="${MIHOMO_SECRET:-changeme}"
MIHOMO_MODE="${MIHOMO_MODE:-rule}"
MIHOMO_LOG_LEVEL="${MIHOMO_LOG_LEVEL:-info}"
MIHOMO_IPV6="${MIHOMO_IPV6:-false}"

GC_EDITOR="${GC_EDITOR:-auto}"
GC_LANGUAGE="${GC_LANGUAGE:-ru}"

MIHOMO_PATTERN="${MIHOMO_PATTERN:-}"
MIHOMO_REPO_OWNER="${MIHOMO_REPO_OWNER:-MetaCubeX}"
MIHOMO_REPO_NAME="${MIHOMO_REPO_NAME:-mihomo}"

ZASHBOARD_REPO_OWNER="${ZASHBOARD_REPO_OWNER:-Zephyruso}"
ZASHBOARD_REPO_NAME="${ZASHBOARD_REPO_NAME:-zashboard}"
ZASHBOARD_ZIP_URL="${ZASHBOARD_ZIP_URL:-https://github.com/Zephyruso/zashboard/releases/latest/download/dist.zip}"

say() {
  printf '%s\n' "$*"
}

ask() {
  printf '%s' "$*"
}

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

die() {
  say "ERROR: $*" >&2
  exit 1
}

as_root() {
  if [ "$(id -u 2>/dev/null)" = "0" ]; then
    "$@"
  elif has_cmd sudo; then
    sudo "$@"
  else
    die "root or sudo required"
  fi
}

ensure_dirs() {
  mkdir -p "$GC_HOME" "$BIN_DIR" "$CONFIG_DIR" "$UI_DIR" "$LOG_DIR" "$RUN_DIR" "$TMP_DIR" "$DATA_DIR" "$CUSTOM_DIR" "$BACKUP_DIR"
}

load_language() {
  if [ -f "$LANG_FILE" ]; then
    GC_LANGUAGE="$(cat "$LANG_FILE" 2>/dev/null | head -n 1)"
  fi

  case "$GC_LANGUAGE" in
    ru|en) ;;
    *) GC_LANGUAGE="ru" ;;
  esac
}

save_language() {
  lang="$1"

  case "$lang" in
    ru|en) ;;
    *) die "available languages: ru, en" ;;
  esac

  ensure_dirs
  printf '%s\n' "$lang" > "$LANG_FILE"
  GC_LANGUAGE="$lang"
}

msg() {
  key="$1"

  case "$GC_LANGUAGE:$key" in
    ru:main_menu) printf '%s' "Главное меню" ;;
    en:main_menu) printf '%s' "Main menu" ;;

    ru:quick_setup) printf '%s' "Быстрая установка" ;;
    en:quick_setup) printf '%s' "Quick setup" ;;

    ru:configs) printf '%s' "Конфиги" ;;
    en:configs) printf '%s' "Configs" ;;

    ru:mihomo) printf '%s' "Mihomo" ;;
    en:mihomo) printf '%s' "Mihomo" ;;

    ru:zashboard) printf '%s' "Zashboard" ;;
    en:zashboard) printf '%s' "Zashboard" ;;

    ru:tools) printf '%s' "Инструменты" ;;
    en:tools) printf '%s' "Tools" ;;

    ru:language) printf '%s' "Язык" ;;
    en:language) printf '%s' "Language" ;;

    ru:exit) printf '%s' "Выход" ;;
    en:exit) printf '%s' "Exit" ;;

    ru:back) printf '%s' "Назад" ;;
    en:back) printf '%s' "Back" ;;

    ru:choose) printf '%s' "Выбери пункт: " ;;
    en:choose) printf '%s' "Choose option: " ;;

    ru:done) printf '%s' "Готово" ;;
    en:done) printf '%s' "Done" ;;

    ru:unknown) printf '%s' "Неизвестный пункт" ;;
    en:unknown) printf '%s' "Unknown option" ;;

    ru:press_enter) printf '%s' "Нажми Enter, чтобы продолжить..." ;;
    en:press_enter) printf '%s' "Press Enter to continue..." ;;

    ru:init_files) printf '%s' "Создать пользовательские файлы" ;;
    en:init_files) printf '%s' "Create user files" ;;

    ru:edit_settings) printf '%s' "Редактировать настройки" ;;
    en:edit_settings) printf '%s' "Edit settings" ;;

    ru:edit_dns) printf '%s' "Редактировать DNS" ;;
    en:edit_dns) printf '%s' "Edit DNS" ;;

    ru:edit_profile) printf '%s' "Редактировать прокси/правила" ;;
    en:edit_profile) printf '%s' "Edit proxies/rules" ;;

    ru:generate_config) printf '%s' "Собрать config.yaml" ;;
    en:generate_config) printf '%s' "Generate config.yaml" ;;

    ru:show_config) printf '%s' "Показать config.yaml" ;;
    en:show_config) printf '%s' "Show config.yaml" ;;

    ru:install_core) printf '%s' "Установить/обновить Mihomo" ;;
    en:install_core) printf '%s' "Install/update Mihomo" ;;

    ru:core_version) printf '%s' "Версия Mihomo" ;;
    en:core_version) printf '%s' "Mihomo version" ;;

    ru:test_config) printf '%s' "Проверить config.yaml" ;;
    en:test_config) printf '%s' "Test config.yaml" ;;

    ru:start) printf '%s' "Запустить" ;;
    en:start) printf '%s' "Start" ;;

    ru:stop) printf '%s' "Остановить" ;;
    en:stop) printf '%s' "Stop" ;;

    ru:restart) printf '%s' "Перезапустить" ;;
    en:restart) printf '%s' "Restart" ;;

    ru:status) printf '%s' "Статус" ;;
    en:status) printf '%s' "Status" ;;

    ru:logs) printf '%s' "Логи" ;;
    en:logs) printf '%s' "Logs" ;;

    ru:install_ui) printf '%s' "Установить/обновить Zashboard" ;;
    en:install_ui) printf '%s' "Install/update Zashboard" ;;

    ru:dashboard_url) printf '%s' "Показать адрес Zashboard" ;;
    en:dashboard_url) printf '%s' "Show Zashboard URL" ;;

    ru:doctor) printf '%s' "Диагностика" ;;
    en:doctor) printf '%s' "Doctor" ;;

    ru:install_deps) printf '%s' "Установить зависимости" ;;
    en:install_deps) printf '%s' "Install dependencies" ;;

    ru:install_editor) printf '%s' "Установить nano" ;;
    en:install_editor) printf '%s' "Install nano" ;;

    ru:paths) printf '%s' "Пути" ;;
    en:paths) printf '%s' "Paths" ;;

    ru:lang_saved) printf '%s' "Язык сохранён" ;;
    en:lang_saved) printf '%s' "Language saved" ;;

    *)
      printf '%s' "$key"
      ;;
  esac
}

pause() {
  say ""
  ask "$(msg press_enter)"
  IFS= read -r _
}

header() {
  say ""
  say "========================================"
  say "$APP_NAME $APP_VERSION"
  say "$1"
  say "========================================"
}

download() {
  out="$1"
  url="$2"

  [ -n "$out" ] || die "download output is empty"
  [ -n "$url" ] || die "download url is empty"

  if has_cmd curl; then
    curl -fL -o "$out" "$url"
  elif has_cmd wget; then
    wget -q --no-check-certificate -O "$out" "$url"
  else
    die "curl or wget is required"
  fi
}

load_settings() {
  if [ -f "$ENV_FILE" ]; then
    . "$ENV_FILE"
  fi
}

create_default_env() {
  cat > "$ENV_FILE" <<'EOF_ENV'
# GoshaCrash user settings

MIHOMO_MIXED_PORT=7890
MIHOMO_API_HOST=127.0.0.1
MIHOMO_API_PORT=9090
MIHOMO_DNS_HOST=127.0.0.1
MIHOMO_DNS_PORT=1053

MIHOMO_ALLOW_LAN=false
MIHOMO_BIND_ADDRESS=127.0.0.1
MIHOMO_SECRET=changeme

MIHOMO_MODE=rule
MIHOMO_LOG_LEVEL=info
MIHOMO_IPV6=false

GC_EDITOR=auto

MIHOMO_PATTERN=

MIHOMO_REPO_OWNER=MetaCubeX
MIHOMO_REPO_NAME=mihomo

ZASHBOARD_REPO_OWNER=Zephyruso
ZASHBOARD_REPO_NAME=zashboard
ZASHBOARD_ZIP_URL=https://github.com/Zephyruso/zashboard/releases/latest/download/dist.zip
EOF_ENV
}

create_default_dns() {
  cat > "$DNS_FILE" <<'EOF_DNS'
dns:
  enable: true
  listen: 127.0.0.1:1053
  ipv6: false
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16

  default-nameserver:
    - 1.1.1.1
    - 8.8.8.8

  nameserver:
    - https://1.1.1.1/dns-query
    - https://8.8.8.8/dns-query

  proxy-server-nameserver:
    - https://1.1.1.1/dns-query

  direct-nameserver:
    - 1.1.1.1
    - 8.8.8.8

  fake-ip-filter:
    - "*.lan"
    - "*.local"
    - "localhost"
    - "router.asus.com"
    - "+.asuscomm.com"
EOF_DNS
}

create_default_profile() {
  cat > "$PROFILE_FILE" <<'EOF_PROFILE'
profile:
  store-selected: true
  store-fake-ip: true

proxies: []

proxy-groups:
  - name: PROXY
    type: select
    proxies:
      - DIRECT

rules:
  - DOMAIN-SUFFIX,lan,DIRECT
  - DOMAIN-SUFFIX,local,DIRECT
  - DOMAIN,localhost,DIRECT
  - IP-CIDR,127.0.0.0/8,DIRECT,no-resolve
  - IP-CIDR,10.0.0.0/8,DIRECT,no-resolve
  - IP-CIDR,172.16.0.0/12,DIRECT,no-resolve
  - IP-CIDR,192.168.0.0/16,DIRECT,no-resolve
  - MATCH,DIRECT
EOF_PROFILE
}

copy_or_create() {
  template="$1"
  target="$2"
  creator="$3"

  if [ -f "$target" ]; then
    return 0
  fi

  if [ -f "$template" ]; then
    cp "$template" "$target"
  else
    "$creator"
  fi
}

init_files() {
  ensure_dirs

  copy_or_create "$TEMPLATE_DIR/env.conf" "$ENV_FILE" create_default_env
  copy_or_create "$TEMPLATE_DIR/dns.yaml" "$DNS_FILE" create_default_dns
  copy_or_create "$TEMPLATE_DIR/profile.yaml" "$PROFILE_FILE" create_default_profile

  load_settings

  header "$(msg init_files)"
  say "GC_HOME:      $GC_HOME"
  say "Settings:     $ENV_FILE"
  say "DNS:          $DNS_FILE"
  say "Profile:      $PROFILE_FILE"
}

detect_target() {
  if has_cmd ipkg; then
    say "asus-optware"
  elif has_cmd opkg; then
    say "asus-entware"
  elif grep -qi microsoft /proc/version 2>/dev/null; then
    say "wsl"
  else
    say "linux"
  fi
}

detect_arch() {
  uname -m 2>/dev/null || say "unknown"
}

detect_editor() {
  load_settings

  if [ "$GC_EDITOR" != "auto" ] && [ -n "$GC_EDITOR" ] && has_cmd "$GC_EDITOR"; then
    say "$GC_EDITOR"
    return 0
  fi

  if [ -n "$EDITOR" ] && has_cmd "$EDITOR"; then
    say "$EDITOR"
    return 0
  fi

  if has_cmd nano; then
    say "nano"
    return 0
  fi

  if has_cmd mcedit; then
    say "mcedit"
    return 0
  fi

  return 1
}

open_editor() {
  file="$1"

  init_files >/dev/null 2>&1

  if editor="$(detect_editor 2>/dev/null)"; then
    "$editor" "$file"
  else
    say "Editor not found."
    say "Run:"
    say "  goshacrash install-editor"
    return 1
  fi
}

install_deps() {
  header "$(msg install_deps)"

  target="$(detect_target)"

  case "$target" in
    asus-optware)
      say "Target: ASUS Optware"
      ipkg update
      ipkg install wget
      ipkg install unzip
      ipkg install gzip
      ipkg install nano
      ;;
    asus-entware)
      say "Target: ASUS Entware"
      opkg update
      opkg install wget
      opkg install unzip
      opkg install gzip
      opkg install nano-full || opkg install nano
      ;;
    *)
      say "Target: Linux/WSL"
      if has_cmd apt-get; then
        as_root apt-get update
        as_root apt-get install -y curl wget unzip gzip ca-certificates nano
      elif has_cmd apt; then
        as_root apt update
        as_root apt install -y curl wget unzip gzip ca-certificates nano
      else
        die "unsupported package manager"
      fi
      ;;
  esac
}

install_editor() {
  header "$(msg install_editor)"

  if has_cmd nano; then
    say "nano already installed: $(command -v nano)"
    return 0
  fi

  if has_cmd ipkg; then
    ipkg update
    ipkg install nano
  elif has_cmd opkg; then
    opkg update
    opkg install nano-full || opkg install nano
  elif has_cmd apt-get; then
    as_root apt-get update
    as_root apt-get install -y nano
  elif has_cmd apt; then
    as_root apt update
    as_root apt install -y nano
  else
    die "no package manager found"
  fi
}

generate_config() {
  init_files >/dev/null 2>&1
  load_settings
  ensure_dirs

  if [ -f "$FINAL_CONFIG" ]; then
    stamp="$(date +%Y%m%d-%H%M%S 2>/dev/null || date)"
    cp "$FINAL_CONFIG" "$BACKUP_DIR/config.yaml.$stamp.bak" 2>/dev/null || true
  fi

  cat > "$FINAL_CONFIG" <<EOF_CONFIG
mixed-port: $MIHOMO_MIXED_PORT
allow-lan: $MIHOMO_ALLOW_LAN
bind-address: "$MIHOMO_BIND_ADDRESS"

mode: $MIHOMO_MODE
log-level: $MIHOMO_LOG_LEVEL
ipv6: $MIHOMO_IPV6

external-controller: $MIHOMO_API_HOST:$MIHOMO_API_PORT
external-ui: "$UI_DIR"
secret: "$MIHOMO_SECRET"

EOF_CONFIG

  cat "$DNS_FILE" >> "$FINAL_CONFIG"
  printf '\n' >> "$FINAL_CONFIG"
  cat "$PROFILE_FILE" >> "$FINAL_CONFIG"

  header "$(msg generate_config)"
  say "$FINAL_CONFIG"
}

show_config() {
  init_files >/dev/null 2>&1

  if [ ! -f "$FINAL_CONFIG" ]; then
    generate_config >/dev/null 2>&1
  fi

  header "$(msg show_config)"
  cat "$FINAL_CONFIG"
}

release_api_url() {
  owner="$1"
  repo="$2"
  say "https://api.github.com/repos/$owner/$repo/releases/latest"
}

fetch_release_json() {
  owner="$1"
  repo="$2"
  out="$3"

  download "$out" "$(release_api_url "$owner" "$repo")"
}

list_assets() {
  json="$1"

  grep '"name":' "$json" 2>/dev/null \
    | sed 's/.*"name": "\(.*\)",*/\1/' \
    | sed 's/",*$//' || true
}

find_asset_url() {
  json="$1"
  patterns="$2"

  for pattern in $patterns; do
    url="$(grep '"browser_download_url":' "$json" 2>/dev/null \
      | sed 's/.*"browser_download_url": "\(.*\)".*/\1/' \
      | grep -E "$pattern" \
      | head -n 1)"

    if [ -n "$url" ]; then
      say "$url"
      return 0
    fi
  done

  return 1
}

mihomo_patterns() {
  load_settings

  if [ -n "$MIHOMO_PATTERN" ]; then
    say "$MIHOMO_PATTERN"
    return
  fi

  arch="$(detect_arch)"
  target="$(detect_target)"

  case "$arch" in
    x86_64|amd64)
      say 'mihomo-linux-amd64-v1.*\.gz$ mihomo-linux-amd64-compatible.*\.gz$ mihomo-linux-amd64.*\.gz$'
      ;;
    aarch64|arm64)
      say 'mihomo-linux-arm64.*\.gz$'
      ;;
    armv7l|armv7*)
      if [ "$target" = "asus-optware" ]; then
        say 'mihomo-linux-armv5.*\.gz$ mihomo-linux-armv7.*\.gz$ mihomo-linux-armv6.*\.gz$'
      else
        say 'mihomo-linux-armv7.*\.gz$ mihomo-linux-armv5.*\.gz$'
      fi
      ;;
    armv6l|armv6*)
      say 'mihomo-linux-armv6.*\.gz$ mihomo-linux-armv5.*\.gz$'
      ;;
    armv5tel|armv5*)
      say 'mihomo-linux-armv5.*\.gz$'
      ;;
    mipsle)
      say 'mihomo-linux-mipsle-softfloat.*\.gz$ mihomo-linux-mipsle.*\.gz$'
      ;;
    mips)
      say 'mihomo-linux-mips-softfloat.*\.gz$ mihomo-linux-mips.*\.gz$'
      ;;
    *)
      say 'mihomo-linux-amd64-v1.*\.gz$'
      ;;
  esac
}

unpack_gzip() {
  src="$1"
  dst="$2"

  if has_cmd gzip; then
    gzip -dc "$src" > "$dst"
  elif has_cmd gunzip; then
    gunzip -c "$src" > "$dst"
  else
    die "gzip or gunzip is required"
  fi
}

install_core() {
  init_files >/dev/null 2>&1
  load_settings
  ensure_dirs

  header "$(msg install_core)"

  release_json="$TMP_DIR/mihomo-release.json"
  patterns="$(mihomo_patterns)"

  say "Target:   $(detect_target)"
  say "Arch:     $(detect_arch)"
  say "Patterns: $patterns"
  say ""

  fetch_release_json "$MIHOMO_REPO_OWNER" "$MIHOMO_REPO_NAME" "$release_json" || die "cannot fetch Mihomo release"

  url="$(find_asset_url "$release_json" "$patterns")"

  if [ -z "$url" ]; then
    say "No suitable Mihomo asset found."
    say ""
    say "Available assets:"
    list_assets "$release_json"
    return 1
  fi

  say "Downloading:"
  say "$url"

  download "$TMP_DIR/mihomo.gz" "$url" || die "cannot download Mihomo"
  unpack_gzip "$TMP_DIR/mihomo.gz" "$TMP_DIR/mihomo" || die "cannot unpack Mihomo"

  chmod +x "$TMP_DIR/mihomo"

  "$TMP_DIR/mihomo" -v >/dev/null 2>&1 || die "downloaded Mihomo cannot run here"

  mv "$TMP_DIR/mihomo" "$MIHOMO_BIN"
  chmod +x "$MIHOMO_BIN"

  say ""
  say "$(msg done): $MIHOMO_BIN"
  "$MIHOMO_BIN" -v | head -n 5
}

core_version() {
  header "$(msg core_version)"

  if [ -x "$MIHOMO_BIN" ]; then
    "$MIHOMO_BIN" -v
  else
    say "Mihomo is not installed."
    say "Run:"
    say "  goshacrash install-core"
  fi
}

test_config() {
  init_files >/dev/null 2>&1
  load_settings

  [ -x "$MIHOMO_BIN" ] || die "Mihomo is not installed. Run: goshacrash install-core"

  if [ ! -f "$FINAL_CONFIG" ]; then
    generate_config >/dev/null 2>&1
  fi

  header "$(msg test_config)"
  "$MIHOMO_BIN" -t -d "$CONFIG_DIR" -f "$FINAL_CONFIG"
}

is_running() {
  if [ -f "$MIHOMO_PID_FILE" ]; then
    pid="$(cat "$MIHOMO_PID_FILE" 2>/dev/null)"
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
  fi

  return 1
}

start_core() {
  init_files >/dev/null 2>&1
  load_settings
  ensure_dirs

  [ -x "$MIHOMO_BIN" ] || die "Mihomo is not installed. Run: goshacrash install-core"

  if [ ! -f "$FINAL_CONFIG" ]; then
    generate_config >/dev/null 2>&1
  fi

  if is_running; then
    header "$(msg status)"
    say "Mihomo already running. PID: $(cat "$MIHOMO_PID_FILE")"
    dashboard_url
    return 0
  fi

  header "$(msg start)"

  nohup "$MIHOMO_BIN" -d "$CONFIG_DIR" -f "$FINAL_CONFIG" > "$MIHOMO_LOG_FILE" 2>&1 &
  pid="$!"
  echo "$pid" > "$MIHOMO_PID_FILE"

  sleep 1

  if is_running; then
    say "Mihomo started. PID: $pid"
    say ""
    say "Proxy:     http://127.0.0.1:$MIHOMO_MIXED_PORT"
    say "API:       http://$MIHOMO_API_HOST:$MIHOMO_API_PORT"
    say "DNS:       $MIHOMO_DNS_HOST:$MIHOMO_DNS_PORT"
    dashboard_url
  else
    say "Mihomo failed to start."
    say ""
    tail -n 80 "$MIHOMO_LOG_FILE" 2>/dev/null || true
    return 1
  fi
}

stop_core() {
  header "$(msg stop)"

  if is_running; then
    pid="$(cat "$MIHOMO_PID_FILE")"
    kill "$pid" 2>/dev/null || true
    sleep 1

    if kill -0 "$pid" 2>/dev/null; then
      kill -9 "$pid" 2>/dev/null || true
    fi

    rm -f "$MIHOMO_PID_FILE"
    say "Stopped."
  else
    rm -f "$MIHOMO_PID_FILE"
    say "Mihomo is not running."
  fi
}

restart_core() {
  stop_core
  start_core
}

status_core() {
  init_files >/dev/null 2>&1
  load_settings

  header "$(msg status)"

  if is_running; then
    say "Mihomo: running"
    say "PID:    $(cat "$MIHOMO_PID_FILE")"
  else
    say "Mihomo: stopped"
  fi

  say ""
  say "Home:      $GC_HOME"
  say "Config:    $FINAL_CONFIG"
  say "Core:      $MIHOMO_BIN"
  say "UI:        $UI_DIR"
  dashboard_url

  if [ -x "$MIHOMO_BIN" ]; then
    say ""
    "$MIHOMO_BIN" -v | head -n 3
  fi
}

logs_core() {
  header "$(msg logs)"

  if [ -f "$MIHOMO_LOG_FILE" ]; then
    if [ "$1" = "-f" ]; then
      tail -f "$MIHOMO_LOG_FILE"
    else
      tail -n 120 "$MIHOMO_LOG_FILE"
    fi
  else
    say "No logs yet: $MIHOMO_LOG_FILE"
  fi
}

install_ui() {
  init_files >/dev/null 2>&1
  load_settings
  ensure_dirs

  header "$(msg install_ui)"

  if ! has_cmd unzip; then
    say "unzip is required."
    say ""
    say "ASUS Optware:"
    say "  ipkg install unzip"
    say ""
    say "WSL/Linux:"
    say "  sudo apt install unzip"
    return 1
  fi

  rm -rf "$TMP_DIR/zashboard-unpack"
  mkdir -p "$TMP_DIR/zashboard-unpack"
  mkdir -p "$UI_DIR"

  say "Downloading:"
  say "$ZASHBOARD_ZIP_URL"

  download "$TMP_DIR/zashboard.zip" "$ZASHBOARD_ZIP_URL" || die "cannot download Zashboard"

  unzip -q "$TMP_DIR/zashboard.zip" -d "$TMP_DIR/zashboard-unpack" || die "cannot unpack Zashboard"

  index_file="$(find "$TMP_DIR/zashboard-unpack" -name index.html -type f 2>/dev/null | head -n 1)"

  if [ -z "$index_file" ]; then
    say "index.html not found after unpack."
    return 1
  fi

  index_dir="$(dirname "$index_file")"

  rm -rf "$UI_DIR"
  mkdir -p "$UI_DIR"

  cp -R "$index_dir"/* "$UI_DIR"/ 2>/dev/null || die "cannot copy Zashboard files"

  say "$(msg done): $UI_DIR"
  dashboard_url
}

dashboard_url() {
  load_settings

  say "Dashboard: http://$MIHOMO_API_HOST:$MIHOMO_API_PORT/ui"
}

quick_setup() {
  init_files
  generate_config
  install_core
  install_ui
  test_config
}

doctor() {
  init_files >/dev/null 2>&1
  load_settings

  header "$(msg doctor)"

  say "Target:     $(detect_target)"
  say "Arch:       $(detect_arch)"
  say "User:       $(whoami 2>/dev/null || echo unknown)"
  say "GC_HOME:    $GC_HOME"
  say "Script:     $SCRIPT_DIR"
  say "Language:   $GC_LANGUAGE"
  say ""

  say "Files:"
  for file in "$ENV_FILE" "$DNS_FILE" "$PROFILE_FILE" "$FINAL_CONFIG" "$MIHOMO_BIN"; do
    if [ -f "$file" ]; then
      say "  OK  $file"
    else
      say "  --  $file"
    fi
  done

  say ""
  say "UI:"
  if [ -f "$UI_DIR/index.html" ]; then
    say "  OK  $UI_DIR/index.html"
  else
    say "  --  $UI_DIR/index.html"
  fi

  say ""
  say "Tools:"
  for cmd in sh curl wget gzip gunzip unzip grep sed awk nano mcedit ipkg opkg apt-get iptables ip; do
    if has_cmd "$cmd"; then
      say "  OK  $cmd: $(command -v "$cmd")"
    else
      say "  --  $cmd"
    fi
  done

  say ""
  if is_running; then
    say "Mihomo: running, PID $(cat "$MIHOMO_PID_FILE")"
  else
    say "Mihomo: stopped"
  fi
}

