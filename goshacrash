#!/bin/sh
# BUILD: 2026-07-16-final-autostart-tun0-yandex-watchdog-110
# GoshaCrash 1.1.0 — pure gVisor TUN, fixed tun0, reboot autostart, fail-open DIRECT.
# Target: ASUS RT-AC68U, Download Master installed, USB-mounted installation.

VERSION="1.1.0"
BUILD_ID="2026-07-16-final-autostart-tun0-yandex-watchdog-110"
SHELLCRASH_REPO="${SHELLCRASH_REPO:-juewuy/ShellCrash}"
SHELLCRASH_BRANCH="${SHELLCRASH_BRANCH:-update}"

MIHOMO_GVISOR_VERSION="${MIHOMO_GVISOR_VERSION:-v1.19.28}"
MIHOMO_GVISOR_REPO="${MIHOMO_GVISOR_REPO:-goshamarat/GoshaCrash}"
MIHOMO_GVISOR_TAG="${MIHOMO_GVISOR_TAG:-mihomo-gvisor-armv5-v1.19.28}"
MIHOMO_GVISOR_ASSET="${MIHOMO_GVISOR_ASSET:-mihomo-linux-armv5-gvisor-v1.19.28.gz}"
MIHOMO_GVISOR_URL="${MIHOMO_GVISOR_URL:-https://github.com/$MIHOMO_GVISOR_REPO/releases/download/$MIHOMO_GVISOR_TAG/$MIHOMO_GVISOR_ASSET}"
MIHOMO_GVISOR_SHA_URL="${MIHOMO_GVISOR_SHA_URL:-$MIHOMO_GVISOR_URL.sha256}"

SCRIPT_DIR="$(CDPATH= cd "$(dirname "$0")" 2>/dev/null && pwd)"
BASE="${GOSHACRASH_BASE:-$SCRIPT_DIR}"
USB_MOUNT="$(dirname "$BASE")"
BIN="$BASE/bin/mihomo"
UI="$BASE/ui"
CONFIG="$BASE/config.yaml"
RUNTIME="$BASE/runtime.yaml"
PREVIOUS="$BASE/runtime.previous.yaml"
PIDFILE="$BASE/run/mihomo.pid"
LOGFILE="$BASE/logs/mihomo.log"
BACKUPS="$BASE/backups"
STATE="$BASE/state"

JFFS_BASE="/jffs/addons/goshacrash"
JFFS_BASE_FILE="$JFFS_BASE/base"
DNS_PORT="${MIHOMO_DNS_PORT:-1053}"
ROUTE_HELPER="$BASE/goshacrash-route"

# Conventional Linux TUN name. No automatic interface-name fallback.
TUN_DEVICE="tun0"
TUN_MTU="${GOSHACRASH_TUN_MTU:-1500}"
TUN_TABLE="${GOSHACRASH_TUN_TABLE:-2022}"
TUN_RULE_INDEX="${GOSHACRASH_TUN_RULE_PREF:-10010}"
TUN_MARK="${GOSHACRASH_TUN_MARK:-0x2333}"
OUTBOUND_MARK_DEC="${GOSHACRASH_OUTBOUND_MARK_DEC:-9012}"
OUTBOUND_MARK_HEX="${GOSHACRASH_OUTBOUND_MARK:-0x2334}"
ROUTE_ROUTER="${GOSHACRASH_ROUTE_ROUTER:-1}"

# These names are cleanup-only. GoshaCrash never creates them anymore.
LEGACY_MANGLE_CHAIN="GOSHACRASH_TUN"
LEGACY_ROUTER_TUN_CHAIN="GOSHACRASH_ROUTER_TUN"
LEGACY_FILTER_CHAIN="GOSHACRASH_FORWARD"
LEGACY_DNS_CHAIN="GOSHACRASH_DNS_HIJACK"
LEGACY_REDIR_CHAIN="GOSHACRASH_TCP_REDIR"
LEGACY_ROUTER_TCP_CHAIN="GOSHACRASH_ROUTER_TCP"
LEGACY_ROUTER_DNS_CHAIN="GOSHACRASH_DNSMASQ_UPSTREAM"

# Automatic WAN watchdog. It runs only while Mihomo is running.
# It never reboots the router and never rewrites config.yaml/runtime.yaml.
WATCHDOG_PIDFILE="$BASE/run/watchdog.pid"
WATCHDOG_LOG="$BASE/logs/watchdog.log"
BOOT_PIDFILE="$BASE/run/boot.pid"
BOOT_LOG="$BASE/logs/boot.log"
VPN_SESSION_FILE="$STATE/vpn-session.active"
DIRECT_REASON_FILE="$STATE/direct-mode.reason"

# Reboot autostart waits for the physical WAN and the ordinary main default route.
BOOT_WAN_WAIT="${GOSHACRASH_BOOT_WAN_WAIT:-300}"
BOOT_WAN_STEP="${GOSHACRASH_BOOT_WAN_STEP:-5}"

# Fail-open watchdog:
# - WAN/link loss: switch to DIRECT within a few seconds;
# - local Mihomo/TUN/routing failure: switch to DIRECT;
# - repeated Internet probe failure: switch to DIRECT;
# - after fail-open it does not restart Mihomo until a manual start or reboot.
WATCHDOG_INTERVAL="${GOSHACRASH_WATCHDOG_INTERVAL:-5}"
WATCHDOG_LOCAL_FAIL_THRESHOLD="${GOSHACRASH_WATCHDOG_LOCAL_FAIL_THRESHOLD:-2}"
WATCHDOG_PROBE_ENABLED="${GOSHACRASH_WATCHDOG_PROBE_ENABLED:-1}"
WATCHDOG_PROBE_INTERVAL="${GOSHACRASH_WATCHDOG_PROBE_INTERVAL:-60}"
WATCHDOG_FAIL_THRESHOLD="${GOSHACRASH_WATCHDOG_FAIL_THRESHOLD:-3}"
WATCHDOG_BOOT_GRACE="${GOSHACRASH_WATCHDOG_BOOT_GRACE:-30}"
# Google-only probes are unsuitable for heavily filtered networks. Success of any
# one regional endpoint is enough; the list can be overridden through the env.
WATCHDOG_URLS="${GOSHACRASH_WATCHDOG_URLS:-https://ya.ru/ https://mail.ru/ https://www.rambler.ru/}"

PATH="/usr/sbin:/usr/bin:/sbin:/bin:/opt/bin:/opt/sbin:/tmp/opt/bin:/tmp/opt/sbin:$USB_MOUNT/asusware.arm/bin:$USB_MOUNT/asusware.arm/sbin:$USB_MOUNT/asusware.arm/opt/bin:$USB_MOUNT/asusware.arm/opt/sbin:$USB_MOUNT/asusware.arm/usr/bin"
export PATH

say(){ printf '%s\n' "[GoshaCrash] $*"; }
warn(){ printf '%s\n' "[GoshaCrash:WARN] $*" >&2; }
fail(){ printf '%s\n' "[GoshaCrash:ERROR] $*" >&2; return 1; }
have(){ which "$1" >/dev/null 2>&1; }

ensure_dirs(){ mkdir -p "$BASE/bin" "$UI" "$BASE/run" "$BASE/logs" "$BACKUPS" "$STATE"; }

set_vpn_session_active(){
    ensure_dirs >/dev/null 2>&1 || true
    date '+%Y-%m-%d %H:%M:%S' > "$VPN_SESSION_FILE" 2>/dev/null || : > "$VPN_SESSION_FILE"
    rm -f "$DIRECT_REASON_FILE"
}

clear_vpn_session(){
    rm -f "$VPN_SESSION_FILE"
}

write_direct_reason(){
    ensure_dirs >/dev/null 2>&1 || true
    reason="$*"
    stamp="$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null)"
    [ -n "$stamp" ] || stamp="unknown-time"
    printf '%s | %s\n' "$stamp" "$reason" > "$DIRECT_REASON_FILE" 2>/dev/null || true
}

is_true(){
    case "$1" in true|True|TRUE|yes|Yes|YES|1|on|On|ON) return 0;; esac
    return 1
}

strip_value(){
    printf '%s\n' "$1" | sed -e 's/[[:space:]]*#.*$//' -e 's/^[[:space:]]*//' \
        -e 's/[[:space:]]*$//' -e 's/^"//' -e 's/"$//' -e "s/^'//" -e "s/'$//"
}

yaml_top(){
    f="$1"; k="$2"
    v="$(awk -v k="$k" '$0 ~ "^[[:space:]]*" k ":[[:space:]]*" {x=$0; sub("^[[:space:]]*" k ":[[:space:]]*","",x); print x; exit}' "$f" 2>/dev/null)"
    strip_value "$v"
}

yaml_section(){
    f="$1"; s="$2"; k="$3"
    v="$(awk -v s="$s" -v k="$k" '
        $0 ~ "^" s ":[[:space:]]*($|#)" {inside=1; next}
        inside && /^[^[:space:]#]/ {exit}
        inside && $0 ~ "^[[:space:]]+" k ":[[:space:]]*" {x=$0; sub("^[[:space:]]+" k ":[[:space:]]*","",x); print x; exit}
    ' "$f" 2>/dev/null)"
    strip_value "$v"
}

lan_ifaces(){
    [ -n "${GOSHACRASH_LAN_IFACES:-}" ] && { echo "$GOSHACRASH_LAN_IFACES"; return; }
    x="$(nvram get lan_ifname 2>/dev/null)"; [ -n "$x" ] || x=br0; echo "$x"
}

lan_ip(){ x="$(nvram get lan_ipaddr 2>/dev/null)"; [ -n "$x" ] || x=192.168.1.1; echo "$x"; }

tun_link_exists(){
    ip link show tun0 >/dev/null 2>&1 || ifconfig tun0 >/dev/null 2>&1
}

load_tun_device(){
    TUN_DEVICE="tun0"
}

choose_tun_device(){
    TUN_DEVICE="tun0"

    # A running Mihomo already owns tun0 and may be reloaded in place.
    running_pid >/dev/null 2>&1 && return 0

    if tun_link_exists; then
        fail "Интерфейс tun0 уже занят другим процессом. Останови его перед запуском GoshaCrash."
        return 1
    fi

    return 0
}

fetch(){
    url="$1"; out="$2"; part="$out.part.$$"; log="/tmp/goshacrash-fetch.$$"
    fetch_home="$STATE/wget-home"
    mkdir -p "$fetch_home" 2>/dev/null || true
    chmod 700 "$fetch_home" 2>/dev/null || true
    rm -f "$part" "$out" "$log"

    if [ -x /usr/sbin/wget ]; then
        downloader=/usr/sbin/wget; kind=wget
    elif have wget; then
        downloader="$(which wget)"; kind=wget
    elif have curl; then
        downloader="$(which curl)"; kind=curl
    else
        fail "Не найден wget или curl"
        return 1
    fi

    say "Загрузчик: $downloader"
    if [ "$kind" = wget ]; then
        HOME="$fetch_home" "$downloader" --no-check-certificate -O "$part" "$url" >"$log" 2>&1
    else
        HOME="$fetch_home" "$downloader" -k -f -L -o "$part" "$url" >"$log" 2>&1
    fi
    rc=$?

    if [ "$rc" -eq 0 ] && [ -s "$part" ]; then
        mv -f "$part" "$out"
        rm -f "$log"
        return 0
    fi

    warn "Не удалось скачать $url"
    [ -s "$log" ] && cat "$log" >&2
    rm -f "$part" "$out" "$log"
    return 1
}

fetch_any(){
    out="$1"
    shift
    retries="${GOSHACRASH_FETCH_RETRIES:-4}"

    for url in "$@"; do
        [ -n "$url" ] || continue
        attempt=1
        while [ "$attempt" -le "$retries" ]; do
            say "Пробую скачать ($attempt/$retries): $url"
            if fetch "$url" "$out"; then
                return 0
            fi
            sleep "$attempt"
            attempt=$((attempt + 1))
        done
    done
    return 1
}

sha256_file(){
    file="$1"
    result=""

    if have sha256sum; then
        result="$(sha256sum "$file" 2>/dev/null | awk 'NR==1 {print $1; exit}')"
        [ -n "$result" ] && { printf '%s\n' "$result"; return 0; }
    fi

    if [ -x /opt/bin/sha256sum ]; then
        result="$(/opt/bin/sha256sum "$file" 2>/dev/null | awk 'NR==1 {print $1; exit}')"
        [ -n "$result" ] && { printf '%s\n' "$result"; return 0; }
    fi

    if [ -x /tmp/opt/bin/sha256sum ]; then
        result="$(/tmp/opt/bin/sha256sum "$file" 2>/dev/null | awk 'NR==1 {print $1; exit}')"
        [ -n "$result" ] && { printf '%s\n' "$result"; return 0; }
    fi

    if have busybox && busybox sha256sum "$file" >/dev/null 2>&1; then
        result="$(busybox sha256sum "$file" 2>/dev/null | awk 'NR==1 {print $1; exit}')"
        [ -n "$result" ] && { printf '%s\n' "$result"; return 0; }
    fi

    if have openssl; then
        result="$(openssl dgst -sha256 "$file" 2>/dev/null | awk 'NR==1 {print $NF; exit}')"
        [ -n "$result" ] && { printf '%s\n' "$result"; return 0; }
    fi

    if [ -x /opt/bin/openssl ]; then
        result="$(/opt/bin/openssl dgst -sha256 "$file" 2>/dev/null | awk 'NR==1 {print $NF; exit}')"
        [ -n "$result" ] && { printf '%s\n' "$result"; return 0; }
    fi

    if [ -x /tmp/opt/bin/openssl ]; then
        result="$(/tmp/opt/bin/openssl dgst -sha256 "$file" 2>/dev/null | awk 'NR==1 {print $NF; exit}')"
        [ -n "$result" ] && { printf '%s\n' "$result"; return 0; }
    fi

    return 1
}

is_asus(){
    have nvram && [ -n "$(nvram get productid 2>/dev/null)" ] && return 0
    uname -a 2>/dev/null | grep -qiE 'asus|brcmarm'
}

core_arch(){
    case "$(uname -m 2>/dev/null)" in
        armv7l|armv7*|armhf)
            # ShellCrash uses armv5 on old ASUS armv7 devices to avoid crashes.
            if is_asus; then echo armv5; else echo armv7; fi;;
        armv5*|armv6*) echo armv5;;
        aarch64|arm64) echo arm64;;
        x86_64|amd64) echo amd64;;
        i?86|x86) echo 386;;
        *) fail "Неподдерживаемая архитектура: $(uname -m)"; return 1;;
    esac
}

install_core_gvisor(){
    a="$1"
    pkg="$BASE/run/$MIHOMO_GVISOR_ASSET"
    sha_file="$pkg.sha256"
    new="$BASE/run/mihomo.new"

    [ "$a" = armv5 ] || {
        fail "Чистая gVisor-сборка подготовлена только для ARMv5, обнаружено: $a"
        return 1
    }

    rm -f "$pkg" "$sha_file" "$new"

    fetch_any "$pkg" "$MIHOMO_GVISOR_URL" || {
        fail "Не удалось скачать ARMv5 gVisor core. Сначала запусти GitHub Actions workflow Build Mihomo ARMv5 gVisor."
        return 1
    }

    fetch_any "$sha_file" "$MIHOMO_GVISOR_SHA_URL" || {
        fail "Не удалось скачать SHA256 для gVisor core"
        rm -f "$pkg"
        return 1
    }

    expected="$(awk 'NR==1 {print $1; exit}' "$sha_file" 2>/dev/null | tr -d '\r' | tr 'A-F' 'a-f')"
    actual="$(sha256_file "$pkg" 2>/dev/null | tr -d '\r' | tr 'A-F' 'a-f')"

    [ -n "$actual" ] || {
        fail "На роутере не найден рабочий SHA-256 инструмент (sha256sum, BusyBox или OpenSSL)"
        rm -f "$pkg" "$sha_file"
        return 1
    }

    [ -n "$expected" ] && [ "$actual" = "$expected" ] || {
        fail "SHA256 gVisor core не совпал: expected=${expected:-EMPTY}, actual=${actual:-EMPTY}"
        rm -f "$pkg" "$sha_file"
        return 1
    }

    say "SHA256 gVisor core: OK ($actual)"

    gzip -dc "$pkg" > "$new" || {
        fail "Не удалось распаковать gVisor core"
        rm -f "$pkg" "$sha_file" "$new"
        return 1
    }
    chmod 755 "$new" || return 1

    version_output="$("$new" -v 2>&1)"
    printf '%s\n' "$version_output" | grep -Fq 'Use tags: with_gvisor' || {
        fail "Скачанный Mihomo собран без with_gvisor"
        printf '%s\n' "$version_output" >&2
        rm -f "$pkg" "$sha_file" "$new"
        return 1
    }

    printf '%s\n' "$version_output" | grep -qi 'linux arm' || {
        fail "Скачанный Mihomo не является Linux ARM-сборкой"
        rm -f "$pkg" "$sha_file" "$new"
        return 1
    }

    rm -f "$pkg" "$sha_file"
    return 0
}

install_core(){
    ensure_dirs || return 1
    a="$(core_arch)" || return 1
    new="$BASE/run/mihomo.new"
    rm -f "$new"

    say "Архитектура ядра: $a"
    say "Источник Mihomo: $MIHOMO_GVISOR_URL"

    install_core_gvisor "$a" || return 1

    [ -f "$BIN" ] && cp "$BIN" "$BIN.previous" 2>/dev/null || true
    mv -f "$new" "$BIN" || return 1
    chmod 755 "$BIN" || return 1
    say "Mihomo gVisor установлен: $($BIN -v 2>/dev/null | head -n 2 | tr '\n' ' ')"
}

find_ui_root(){
    ex="$1"
    [ -f "$ex/index.html" ] && { echo "$ex"; return 0; }
    for d in "$ex"/*; do
        [ -d "$d" ] && [ -f "$d/index.html" ] && { echo "$d"; return 0; }
    done
    if have find; then
        idx="$(find "$ex" -name index.html -type f 2>/dev/null | head -n 1)"
        [ -n "$idx" ] && { dirname "$idx"; return 0; }
    fi
    return 1
}

install_ui(){
    ensure_dirs || return 1
    tgz="$BASE/run/zashboard.tar.gz"
    ex="$BASE/run/zashboard.extract"
    newui="$BASE/run/ui.new"
    rm -rf "$ex" "$newui"
    mkdir -p "$ex" "$newui" || return 1

    if [ -n "${ZASHBOARD_URL:-}" ]; then
        fetch_any "$tgz" "$ZASHBOARD_URL" || return 1
    else
        fetch_any "$tgz" \
            "https://testingcf.jsdelivr.net/gh/$SHELLCRASH_REPO@$SHELLCRASH_BRANCH/bin/dashboard/zashboard.tar.gz" \
            "https://cdn.jsdelivr.net/gh/$SHELLCRASH_REPO@$SHELLCRASH_BRANCH/bin/dashboard/zashboard.tar.gz" \
            "https://raw.githubusercontent.com/$SHELLCRASH_REPO/$SHELLCRASH_BRANCH/bin/dashboard/zashboard.tar.gz" \
            "https://github.com/$SHELLCRASH_REPO/raw/$SHELLCRASH_BRANCH/bin/dashboard/zashboard.tar.gz" || return 1
    fi

    tar -tzf "$tgz" >/dev/null 2>&1 || {
        fail "Получен повреждённый архив Zashboard"
        rm -f "$tgz"
        return 1
    }
    tar -xzf "$tgz" -C "$ex" >/dev/null 2>&1 || return 1
    ui_root="$(find_ui_root "$ex")" || {
        fail "В архиве Zashboard нет index.html"
        rm -rf "$ex" "$tgz"
        return 1
    }
    cp -R "$ui_root"/. "$newui"/ || return 1
    [ -f "$newui/index.html" ] || return 1

    rm -rf "$UI.previous"
    [ -d "$UI" ] && mv "$UI" "$UI.previous" 2>/dev/null || true
    mv "$newui" "$UI" || {
        [ -d "$UI.previous" ] && mv "$UI.previous" "$UI"
        return 1
    }
    rm -rf "$ex" "$tgz"
    say "Zashboard установлен по сети"
}

detect_dns_mode(){
    f="$1"
    listen="$(
        awk '
        {
            line=$0
            sub(/\r$/, "", line)
            sub(/[[:space:]]*#.*/, "", line)
            sub(/[[:space:]]*$/, "", line)

            if (line ~ /^dns:[[:space:]]*$/) {
                inside=1
                next
            }

            if (inside && line ~ /^[^[:space:]]/) {
                inside=0
            }

            if (inside && line ~ /^[[:space:]]+enable:[[:space:]]*/) {
                x=line
                sub(/^[[:space:]]+enable:[[:space:]]*/, "", x)
                enabled=x
            }

            if (inside && line ~ /^[[:space:]]+listen:[[:space:]]*/) {
                x=line
                sub(/^[[:space:]]+listen:[[:space:]]*/, "", x)
                listen=x
            }
        }

        END {
            if ((enabled == "true" || enabled == "True" || enabled == "TRUE" ||
                 enabled == "yes"  || enabled == "Yes"  || enabled == "YES"  ||
                 enabled == "1"    || enabled == "on"   || enabled == "On"   ||
                 enabled == "ON") && listen != "") {
                print listen
            }
        }
        ' "$f" 2>/dev/null
    )"

    listen="$(strip_value "$listen")"
    [ -n "$listen" ] || { echo none; return; }

    p="${listen##*:}"
    p="$(printf '%s\n' "$p" | sed 's/[^0-9].*$//')"

    case "$p" in
        53) echo exclusive53 ;;
        '') echo none ;;
        *) echo "forward:$p" ;;
    esac
}

extract_yaml_section(){
    file="$1"
    section="$2"
    output="$3"

    awk -v section="$section" '
        { sub(/\r$/, "") }
        $0 ~ "^" section ":[[:space:]]*($|#)" {
            inside=1
            print
            next
        }
        inside && /^[^[:space:]#]/ { exit }
        inside { print }
    ' "$file" > "$output"
}

verify_runtime_requirements(){
    file="$1"

    [ -x "$BIN" ] && "$BIN" -v 2>&1 | grep -Fq 'Use tags: with_gvisor' || {
        fail "Установленный Mihomo не содержит with_gvisor"
        return 1
    }

    is_true "$(yaml_section "$file" tun enable)" || {
        fail "runtime: tun.enable должен быть true"
        return 1
    }

    [ "$(yaml_section "$file" tun stack)" = gvisor ] || {
        fail "runtime: чистый TUN требует tun.stack=gvisor"
        return 1
    }

    is_true "$(yaml_section "$file" tun auto-route)" && {
        fail "runtime: tun.auto-route должен быть false"
        return 1
    }

    is_true "$(yaml_section "$file" tun auto-redirect)" && {
        fail "runtime: tun.auto-redirect должен быть false"
        return 1
    }

    is_true "$(yaml_section "$file" tun auto-detect-interface)" && {
        fail "runtime: tun.auto-detect-interface должен быть false"
        return 1
    }

    [ "$(yaml_section "$file" tun device)" = "$TUN_DEVICE" ] || {
        fail "runtime: ожидается tun.device=$TUN_DEVICE"
        return 1
    }

    [ "$(yaml_top "$file" routing-mark)" = "$OUTBOUND_MARK_DEC" ] || {
        fail "runtime: ожидается routing-mark=$OUTBOUND_MARK_DEC"
        return 1
    }

    listen="$(yaml_section "$file" dns listen)"
    [ "$listen" = "127.0.0.1:$DNS_PORT" ] || {
        fail "runtime DNS должен слушать 127.0.0.1:$DNS_PORT"
        return 1
    }

    return 0
}

render_runtime(){
    out="$1"
    [ -f "$CONFIG" ] || return 1

    cp "$CONFIG" "$out" || return 1
    tr -d '\r' < "$out" > "$out.lf" || return 1
    mv -f "$out.lf" "$out" || return 1

    controller_addr="$(yaml_top "$CONFIG" external-controller)"
    controller_port="${controller_addr##*:}"
    case "$controller_port" in
        ''|*[!0-9]*) controller_port=9090;;
    esac

    # Корневые runtime-параметры под старый ASUSWRT:
    # API открыт в LAN, IPv6/поиск процессов отключены, а исходящие сокеты
    # Mihomo получают отдельную метку для защиты от зацикливания.
    awk -v cp="$controller_port" -v mark="$OUTBOUND_MARK_DEC" '
        BEGIN {
            have_controller=0
            have_mark=0
            have_ipv6=0
            have_find=0
        }
        /^[^[:space:]#][^:]*:[[:space:]]*/ {
            key=$0
            sub(/:.*/, "", key)

            if (key == "external-controller") {
                print "external-controller: 0.0.0.0:" cp
                have_controller=1
                next
            }
            if (key == "routing-mark") {
                print "routing-mark: " mark
                have_mark=1
                next
            }
            if (key == "ipv6") {
                print "ipv6: false"
                have_ipv6=1
                next
            }
            if (key == "find-process-mode") {
                print "find-process-mode: off"
                have_find=1
                next
            }
            if (key == "mixed-port" || key == "port" || key == "socks-port" || key == "redir-port" || key == "tproxy-port")
                next
        }
        { print }
        END {
            if (!have_controller) print "external-controller: 0.0.0.0:" cp
            if (!have_mark) print "routing-mark: " mark
            if (!have_ipv6) print "ipv6: false"
            if (!have_find) print "find-process-mode: off"
        }
    ' "$out" > "$out.root" || return 1
    mv -f "$out.root" "$out" || return 1

    grep -Eq '^external-ui:[[:space:]]*' "$out" ||
        printf '\nexternal-ui: ui\n' >> "$out"

    if ! grep -Eq '^dns:[[:space:]]*($|#)' "$out"; then
        cat >> "$out" <<DNS_RUNTIME

dns:
  enable: true
  listen: 127.0.0.1:$DNS_PORT
  ipv6: false
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  nameserver:
    - 1.1.1.1
    - 9.9.9.9
DNS_RUNTIME
    fi

    # В DNS меняются только listen и IPv6. Остальные пользовательские
    # nameserver/policy/fallback/hosts сохраняются.
    awk -v p="$DNS_PORT" '
        function finish_dns() {
            if (!seen_listen) print "  listen: 127.0.0.1:" p
            if (!seen_ipv6) print "  ipv6: false"
        }
        /^dns:[[:space:]]*($|#)/ {
            inside=1
            seen_listen=0
            seen_ipv6=0
            print
            next
        }
        inside && /^[^[:space:]#]/ {
            finish_dns()
            inside=0
        }
        inside && /^[[:space:]]+listen:[[:space:]]*/ {
            print "  listen: 127.0.0.1:" p
            seen_listen=1
            next
        }
        inside && /^[[:space:]]+ipv6:[[:space:]]*/ {
            print "  ipv6: false"
            seen_ipv6=1
            next
        }
        { print }
        END { if (inside) finish_dns() }
    ' "$out" > "$out.dns" || return 1
    mv -f "$out.dns" "$out" || return 1

    # TUN в runtime всегда совместимый. Личный config.yaml не изменяется.
    awk -v dev="$TUN_DEVICE" -v mtu="$TUN_MTU" '
        function emit() {
            print "tun:"
            print "  enable: true"
            print "  stack: gvisor"
            print "  device: " dev
            print "  mtu: " mtu
            print "  dns-hijack:"
            print "    - any:53"
            print "    - tcp://any:53"
            print "  auto-route: false"
            print "  auto-redirect: false"
            print "  auto-detect-interface: false"
            print "  strict-route: false"
            print "  gso: false"
        }
        /^tun:[[:space:]]*($|#)/ {
            if (!done) {
                emit()
                done=1
            }
            skip=1
            next
        }
        skip && /^[^[:space:]#]/ { skip=0 }
        !skip { print }
        END {
            if (!done) {
                print ""
                emit()
            }
        }
    ' "$out" > "$out.tun" || return 1
    mv -f "$out.tun" "$out" || return 1

    verify_runtime_requirements "$out"
}

runtime_audit(){
    [ -f "$RUNTIME" ] || {
        fail "Нет $RUNTIME"
        return 1
    }

    verify_runtime_requirements "$RUNTIME" || return 1

    echo "runtime.yaml: OK"
    echo "GoshaCrash меняет только транспортные параметры:"
    echo "  external-controller -> $(yaml_top "$RUNTIME" external-controller)"
    echo "  routing-mark -> $(yaml_top "$RUNTIME" routing-mark)"
    echo "  ipv6 -> $(yaml_top "$RUNTIME" ipv6)"
    echo "  find-process-mode -> $(yaml_top "$RUNTIME" find-process-mode)"
    echo "  dns.listen -> $(yaml_section "$RUNTIME" dns listen)"
    echo "Чистый gVisor TUN:"
    audit_tun="/tmp/goshacrash-tun-audit.$$"
    extract_yaml_section "$RUNTIME" tun "$audit_tun"
    cat "$audit_tun"
    rm -f "$audit_tun"
}

runtime_render_only(){
    ensure_dirs || return 1
    choose_tun_device || return 1
    candidate="$BASE/run/runtime.render-test.yaml"
    rm -f "$candidate"
    render_runtime "$candidate" || return 1
    echo "$candidate"
}

mihomo_pids(){
    for proc in /proc/[0-9]*; do
        [ -r "$proc/cmdline" ] || continue
        pid="${proc##*/}"
        [ "$pid" = "$$" ] && continue
        cmd="$(tr '\000' ' ' < "$proc/cmdline" 2>/dev/null)"
        case "$cmd" in
            "$BIN"|"$BIN "*) printf '%s\n' "$pid";;
        esac
    done
}

running_pid(){
    if [ -f "$PIDFILE" ]; then
        p="$(cat "$PIDFILE" 2>/dev/null)"
        case "$p" in ''|*[!0-9]*) p="";; esac
        if [ -n "$p" ] && kill -0 "$p" 2>/dev/null; then
            cmd="$(tr '\000' ' ' < "/proc/$p/cmdline" 2>/dev/null)"
            case "$cmd" in "$BIN"|"$BIN "*) echo "$p"; return 0;; esac
        fi
    fi

    p="$(mihomo_pids | sed -n '1p')"
    [ -n "$p" ] || return 1
    echo "$p" > "$PIDFILE" 2>/dev/null || true
    echo "$p"
}

kill_mihomo(){
    # Never trust a stale pidfile: only terminate processes whose /proc/cmdline
    # starts with the exact installed Mihomo binary path.
    pids="$(mihomo_pids)"

    for p in $pids; do
        case "$p" in ''|*[!0-9]*) continue;; esac
        kill "$p" 2>/dev/null || true
    done

    n=0
    while [ "$n" -lt 10 ]; do
        alive=0
        for p in $pids; do
            case "$p" in ''|*[!0-9]*) continue;; esac
            kill -0 "$p" 2>/dev/null && alive=1
        done
        [ "$alive" -eq 0 ] && break
        sleep 1
        n=$((n + 1))
    done

    for p in $pids; do
        case "$p" in ''|*[!0-9]*) continue;; esac
        kill -0 "$p" 2>/dev/null && kill -9 "$p" 2>/dev/null || true
    done
    rm -f "$PIDFILE"
}

check_file(){ [ -x "$BIN" ] || { fail "Не найден $BIN"; return 1; }; "$BIN" -t -d "$BASE" -f "$1"; }

validate_runtime(){
    check_file "$RUNTIME" && return 0

    warn "runtime.yaml повреждён или не проходит проверку"
    [ -f "$PREVIOUS" ] || return 1
    check_file "$PREVIOUS" >/dev/null 2>&1 || {
        warn "runtime.previous.yaml тоже не проходит проверку"
        return 1
    }

    ensure_dirs || return 1
    stamp="$(date '+%Y%m%d-%H%M%S' 2>/dev/null)"
    [ -n "$stamp" ] || stamp="broken"
    cp "$RUNTIME" "$BASE/run/runtime.invalid-$stamp.yaml" 2>/dev/null || true
    cp "$PREVIOUS" "$RUNTIME" || return 1
    say "После сбоя восстановлен предыдущий runtime.yaml"
    check_file "$RUNTIME"
}

ensure_tun(){
    [ -c /dev/net/tun ] && return 0
    modprobe tun >/dev/null 2>&1 || true
    m="/lib/modules/$(uname -r)/kernel/drivers/net/tun.ko"; [ -c /dev/net/tun ] || { [ -f "$m" ] && insmod "$m" >/dev/null 2>&1 || true; }
    if [ ! -c /dev/net/tun ]; then mkdir -p /dev/net 2>/dev/null; mknod /dev/net/tun c 10 200 2>/dev/null; chmod 666 /dev/net/tun 2>/dev/null; fi
    [ -c /dev/net/tun ]
}

tun_enabled(){ [ -f "$RUNTIME" ] && is_true "$(yaml_section "$RUNTIME" tun enable)"; }
tun_device(){ x="$(yaml_section "$RUNTIME" tun device)"; [ -n "$x" ] || x="$TUN_DEVICE"; echo "$x"; }

wait_port(){
    p="$1"; n=0
    while [ "$n" -lt 15 ]; do netstat -ln 2>/dev/null | grep -Eq "[:.]$p[[:space:]]" && return 0; sleep 1; n=$((n+1)); done
    return 1
}

wait_tun(){
    tun_enabled || return 0; d="$(tun_device)"; n=0
    while [ "$n" -lt 15 ]; do ip link show "$d" >/dev/null 2>&1 && return 0; ifconfig "$d" >/dev/null 2>&1 && return 0; sleep 1; n=$((n+1)); done
    return 1
}

route_helper(){
    [ -x "$ROUTE_HELPER" ] || {
        fail "Не найден routing helper: $ROUTE_HELPER"
        return 1
    }

    GOSHACRASH_BASE="$BASE" \
    GOSHACRASH_TUN_DEVICE="$(tun_device)" \
    GOSHACRASH_TUN_TABLE="$TUN_TABLE" \
    GOSHACRASH_TUN_RULE_PREF="$TUN_RULE_INDEX" \
    GOSHACRASH_TUN_MARK="$TUN_MARK" \
    GOSHACRASH_OUTBOUND_MARK="$OUTBOUND_MARK_HEX" \
    GOSHACRASH_ROUTE_ROUTER="$ROUTE_ROUTER" \
    MIHOMO_DNS_PORT="$DNS_PORT" \
        "$ROUTE_HELPER" "$1" "$(tun_device)"
}

fallback_remove_jump(){
    table="$1"
    chain="$2"
    shift 2
    while iptables -t "$table" -D "$chain" "$@" 2>/dev/null; do :; done
}

fallback_delete_chain(){
    table="$1"
    chain="$2"
    iptables -t "$table" -F "$chain" 2>/dev/null || true
    iptables -t "$table" -X "$chain" 2>/dev/null || true
}

fallback_cleanup_network(){
    if have iptables; then
        for iface in $(lan_ifaces); do
            fallback_remove_jump mangle PREROUTING -i "$iface" -j GOSHACRASH_TUN_LAN
            fallback_remove_jump nat PREROUTING -i "$iface" -p udp --dport 53 -j GOSHACRASH_DNS_LAN
            fallback_remove_jump nat PREROUTING -i "$iface" -p tcp --dport 53 -j GOSHACRASH_DNS_LAN
            fallback_remove_jump mangle PREROUTING -i "$iface" -j GOSHACRASH_TUN
            fallback_remove_jump nat PREROUTING -i "$iface" -p tcp -j GOSHACRASH_TCP_REDIR
            fallback_remove_jump nat PREROUTING -i "$iface" -p udp --dport 53 -j GOSHACRASH_DNS_HIJACK
            fallback_remove_jump nat PREROUTING -i "$iface" -p tcp --dport 53 -j GOSHACRASH_DNS_HIJACK
        done

        fallback_remove_jump mangle OUTPUT -j GOSHACRASH_TUN_ROUTER
        fallback_remove_jump nat OUTPUT -p udp --dport 53 -j GOSHACRASH_DNS_OUT
        fallback_remove_jump nat OUTPUT -p tcp --dport 53 -j GOSHACRASH_DNS_OUT
        fallback_remove_jump filter FORWARD -j GOSHACRASH_TUN_FORWARD
        fallback_remove_jump mangle OUTPUT -j GOSHACRASH_ROUTER_TUN
        fallback_remove_jump nat OUTPUT -p tcp -j GOSHACRASH_ROUTER_TCP
        fallback_remove_jump nat OUTPUT -p udp --dport 53 -j GOSHACRASH_DNSMASQ_UPSTREAM
        fallback_remove_jump nat OUTPUT -p tcp --dport 53 -j GOSHACRASH_DNSMASQ_UPSTREAM
        fallback_remove_jump filter FORWARD -j GOSHACRASH_FORWARD

        for chain in GOSHACRASH_TUN_LAN GOSHACRASH_TUN_ROUTER GOSHACRASH_TUN GOSHACRASH_ROUTER_TUN; do
            fallback_delete_chain mangle "$chain"
        done
        for chain in GOSHACRASH_DNS_LAN GOSHACRASH_DNS_OUT GOSHACRASH_DNS_HIJACK GOSHACRASH_TCP_REDIR GOSHACRASH_ROUTER_TCP GOSHACRASH_DNSMASQ_UPSTREAM; do
            fallback_delete_chain nat "$chain"
        done
        for chain in GOSHACRASH_TUN_FORWARD GOSHACRASH_FORWARD; do
            fallback_delete_chain filter "$chain"
        done
    fi

    while ip rule del fwmark "$TUN_MARK" table "$TUN_TABLE" pref "$TUN_RULE_INDEX" 2>/dev/null; do :; done
    while ip rule del fwmark "$TUN_MARK" table "$TUN_TABLE" 2>/dev/null; do :; done
    ip route flush table "$TUN_TABLE" 2>/dev/null || true
    ip route flush cache 2>/dev/null || true
}

cleanup_legacy_network(){
    if [ -x "$ROUTE_HELPER" ]; then
        route_helper stop >/dev/null 2>&1 || fallback_cleanup_network
    else
        fallback_cleanup_network
    fi
}

enter_direct_mode(){
    reason="${1:-fail-open}"
    watchdog_log "FAIL-OPEN -> DIRECT: $reason"
    cleanup_legacy_network
    kill_mihomo
    clear_vpn_session
    write_direct_reason "$reason"
}

sync_runtime_tun_device(){
    [ -f "$RUNTIME" ] || return 0
    current="$(yaml_section "$RUNTIME" tun device)"
    [ "$current" = "$TUN_DEVICE" ] && return 0

    candidate="$BASE/run/runtime.device-switch.yaml"
    rm -f "$candidate"
    render_runtime "$candidate" || return 1
    check_file "$candidate" || { rm -f "$candidate"; return 1; }
    cp "$RUNTIME" "$PREVIOUS" 2>/dev/null || true
    mv -f "$candidate" "$RUNTIME" || return 1
    say "TUN-интерфейс runtime переключён: ${current:-unknown} -> $TUN_DEVICE"
}

start_mihomo(){
    [ "${GOSHACRASH_BOOT_INTERNAL:-0}" = 1 ] || boot_stop

    [ -f "$RUNTIME" ] || {
        fail "Сначала выполни: goshacrash apply"
        return 1
    }

    choose_tun_device || return 1
    sync_runtime_tun_device || return 1

    watchdog_wan_available || {
        enter_direct_mode "WAN-кабель, carrier или основной default route недоступны при запуске"
        fail "WAN недоступен; оставлен обычный DIRECT"
        return 1
    }

    if p="$(running_pid)"; then
        route_helper reload || {
            enter_direct_mode "не удалось восстановить правила для уже запущенного Mihomo"
            return 1
        }
        set_vpn_session_active
        [ "${GOSHACRASH_WATCHDOG_INTERNAL:-0}" = 1 ] || watchdog_start || true
        echo "Mihomo уже запущен, PID=$p"
        return 0
    fi

    [ -x "$ROUTE_HELPER" ] || {
        fail "Не установлен $ROUTE_HELPER"
        return 1
    }
    ensure_tun || {
        fail "Нет /dev/net/tun"
        return 1
    }
    validate_runtime || return 1

    cleanup_legacy_network
    ensure_dirs || return 1
    rm -f "$PIDFILE"
    [ -f "$LOGFILE" ] && [ "$(wc -c < "$LOGFILE" 2>/dev/null)" -gt 1048576 ] 2>/dev/null &&
        mv -f "$LOGFILE" "$LOGFILE.previous"

    GOGC="${GOGC:-50}" "$BIN" -d "$BASE" -f "$RUNTIME" >> "$LOGFILE" 2>&1 &
    p=$!
    echo "$p" > "$PIDFILE"
    sleep 2

    running_pid >/dev/null 2>&1 || {
        fail "Mihomo завершился"
        tail -n 100 "$LOGFILE"
        return 1
    }

    wait_port "$DNS_PORT" || {
        kill_mihomo
        fail "Mihomo DNS не слушает порт $DNS_PORT"
        tail -n 100 "$LOGFILE"
        return 1
    }

    wait_tun || {
        kill_mihomo
        fail "Mihomo не создал TUN-интерфейс"
        tail -n 100 "$LOGFILE"
        return 1
    }

    route_helper start || {
        kill_mihomo
        cleanup_legacy_network
        clear_vpn_session
        write_direct_reason "маршрутизация TUN не поднялась"
        fail "Совместимая маршрутизация не поднялась; оставлен обычный DIRECT"
        return 1
    }

    set_vpn_session_active
    echo "Mihomo запущен, PID=$(cat "$PIDFILE" 2>/dev/null)"
    echo "[GoshaCrash] Чистый TUN: TCP+UDP -> $TUN_DEVICE -> Mihomo gVisor; auto-route=off"
    [ "${GOSHACRASH_WATCHDOG_INTERNAL:-0}" = 1 ] || watchdog_start || true
}

stop_mihomo(){
    [ "${GOSHACRASH_BOOT_INTERNAL:-0}" = 1 ] || boot_stop
    [ "${GOSHACRASH_WATCHDOG_INTERNAL:-0}" = 1 ] || watchdog_stop
    enter_direct_mode "ручная остановка"
    echo "Mihomo и tun0 остановлены; трафик переведён в обычный DIRECT"
}

backup_config(){
    ensure_dirs || return 1; [ -f "$CONFIG" ] || return 1
    s="$(date '+%Y%m%d-%H%M%S' 2>/dev/null)"; [ -n "$s" ] || s=backup
    f="$BACKUPS/config-$s.yaml"; cp "$CONFIG" "$f" || return 1; echo "$f"
}

install_hooks(){
    opt="$USB_MOUNT/asusware.arm"; [ -d "$opt" ] || { fail "Не найден Download Master: $opt"; return 1; }
    init="$opt/etc/init.d/S99goshacrash"; ctl="$opt/lib/ipkg/info/goshacrash.control"
    mkdir -p "$(dirname "$init")" "$(dirname "$ctl")" "$JFFS_BASE" || return 1
    echo "$BASE" > "$JFFS_BASE_FILE" || return 1
    cat > "$init" <<HOOK
#!/bin/sh
BASE_FILE="$JFFS_BASE_FILE"
BASE="$BASE"
[ -f "\$BASE_FILE" ] && { x="\$(cat "\$BASE_FILE" 2>/dev/null)"; [ -n "\$x" ] && BASE="\$x"; }
CTL="\$BASE/goshacrash"
case "\$1" in
 start)
   sleep 5
   if [ -x "\$CTL" ]; then
     mkdir -p "\$BASE/logs" "\$BASE/run" 2>/dev/null || true
     if command -v nohup >/dev/null 2>&1; then
       GOSHACRASH_BASE="\$BASE" nohup "\$CTL" boot </dev/null >>"\$BASE/logs/boot.log" 2>&1 &
     else
       GOSHACRASH_BASE="\$BASE" "\$CTL" boot </dev/null >>"\$BASE/logs/boot.log" 2>&1 &
     fi
   fi
   ;;
 restart|force-reload)
   [ -x "\$CTL" ] && GOSHACRASH_BASE="\$BASE" "\$CTL" stop >/dev/null 2>&1 || true
   if [ -x "\$CTL" ]; then
     mkdir -p "\$BASE/logs" "\$BASE/run" 2>/dev/null || true
     if command -v nohup >/dev/null 2>&1; then
       GOSHACRASH_BASE="\$BASE" nohup "\$CTL" boot </dev/null >>"\$BASE/logs/boot.log" 2>&1 &
     else
       GOSHACRASH_BASE="\$BASE" "\$CTL" boot </dev/null >>"\$BASE/logs/boot.log" 2>&1 &
     fi
   fi
   ;;
 stop) [ -x "\$CTL" ] && GOSHACRASH_BASE="\$BASE" "\$CTL" stop;;
 firewall-start|firewall-restart) [ -x "\$CTL" ] && GOSHACRASH_BASE="\$BASE" "\$CTL" firewall-reload;;
 *) exit 0;;
esac
exit 0
HOOK
    chmod 755 "$init" || return 1
    cat > "$ctl" <<CONTROL
Package: goshacrash
Architecture: arm
Priority: optional
Section: net
Version: $VERSION
Maintainer: GoshaCrash
Source: local
Description: Mihomo and Zashboard controller for stock ASUSWRT
Depends:
Suggests:
Conflicts:
Enabled: yes
CONTROL
    mkdir -p /opt/lib/ipkg/info 2>/dev/null || true; cp "$ctl" /opt/lib/ipkg/info/goshacrash.control 2>/dev/null || true
    say "Автозапуск установлен: $init"
}

uninstall_hooks(){
    stop_mihomo >/dev/null 2>&1 || true; opt="$USB_MOUNT/asusware.arm"
    rm -f "$opt/etc/init.d/S99goshacrash" "$opt/lib/ipkg/info/goshacrash.control" /opt/lib/ipkg/info/goshacrash.control
    rm -rf "$JFFS_BASE"; say "Автозапуск удалён"
}

apply_config(){
    [ -f "$CONFIG" ] || { fail "Не найден $CONFIG"; return 1; }; ensure_dirs || return 1
    choose_tun_device || return 1
    b="$(backup_config)" || return 1; say "Резервная копия: $b"
    cand="$BASE/run/runtime.candidate.yaml"; rm -f "$cand"; render_runtime "$cand" || return 1
    [ -f "$RUNTIME" ] && cp "$RUNTIME" "$PREVIOUS" 2>/dev/null || rm -f "$PREVIOUS"
    stop_mihomo >/dev/null 2>&1 || true
    say "Проверяю runtime.yaml"; check_file "$cand" || { rm -f "$cand"; [ -f "$PREVIOUS" ] && { cp "$PREVIOUS" "$RUNTIME"; start_mihomo >/dev/null 2>&1 || true; }; return 1; }
    mv -f "$cand" "$RUNTIME" || return 1; install_hooks || return 1
    start_mihomo || { fail "Новый конфиг не запустился"; [ -f "$PREVIOUS" ] && { cp "$PREVIOUS" "$RUNTIME"; start_mihomo >/dev/null 2>&1 || true; }; return 1; }
    say "Конфиг применён"; status
}

check_config(){ ensure_dirs || return 1; choose_tun_device || return 1; t="$BASE/run/check.yaml"; render_runtime "$t" || return 1; check_file "$t"; r=$?; rm -f "$t"; return "$r"; }

boot_pid(){
    [ -f "$BOOT_PIDFILE" ] || return 1
    p="$(cat "$BOOT_PIDFILE" 2>/dev/null)"
    case "$p" in ''|*[!0-9]*) return 1;; esac
    kill -0 "$p" 2>/dev/null || return 1

    # Never trust a stale PID file: verify the exact GoshaCrash boot process.
    [ -r "/proc/$p/cmdline" ] || return 1
    cmd="$(tr '\000' ' ' < "/proc/$p/cmdline" 2>/dev/null)"
    case "$cmd" in
        *"$BASE/goshacrash boot"*) ;;
        *) return 1;;
    esac

    printf '%s\n' "$p"
}

boot_stop(){
    if p="$(boot_pid)"; then
        [ "$p" = "$$" ] && return 0
        kill "$p" 2>/dev/null || true
        n=0
        while kill -0 "$p" 2>/dev/null && [ "$n" -lt 5 ]; do
            sleep 1
            n=$((n + 1))
        done
        kill -0 "$p" 2>/dev/null && kill -9 "$p" 2>/dev/null || true
    fi
    rm -f "$BOOT_PIDFILE"
}

boot_service(){
    # Prevent duplicate S99/restart invocations from launching parallel waiters.
    if old_boot_pid="$(boot_pid)"; then
        if [ "$old_boot_pid" != "$$" ]; then
            say "Автозапуск уже ожидает WAN, PID=$old_boot_pid"
            return 0
        fi
    fi

    ensure_dirs || return 1
    echo "$$" > "$BOOT_PIDFILE"
    cleanup_boot_pid(){
        saved="$(cat "$BOOT_PIDFILE" 2>/dev/null)"
        [ "$saved" = "$$" ] && rm -f "$BOOT_PIDFILE"
    }
    trap 'cleanup_boot_pid; exit 0' TERM INT HUP
    trap 'cleanup_boot_pid' EXIT

    n=0
    while [ ! -x "$BIN" ] && [ "$n" -lt 30 ]; do
        sleep 2
        n=$((n + 1))
    done

    [ -x "$BIN" ] || {
        enter_direct_mode "автозапуск: бинарник Mihomo не найден"
        return 1
    }
    [ -f "$RUNTIME" ] || {
        enter_direct_mode "автозапуск: runtime.yaml не найден"
        return 1
    }

    watchdog_stop
    cleanup_legacy_network
    kill_mihomo
    clear_vpn_session

    waited=0
    while ! watchdog_wan_available; do
        if [ "$waited" -ge "$BOOT_WAN_WAIT" ]; then
            enter_direct_mode "автозапуск: WAN не появился за ${BOOT_WAN_WAIT} секунд"
            warn "WAN не появился; роутер оставлен в DIRECT"
            return 0
        fi
        sleep "$BOOT_WAN_STEP"
        waited=$((waited + BOOT_WAN_STEP))
    done

    say "WAN готов; автоматически запускаю Mihomo и tun0"
    GOSHACRASH_BOOT_INTERNAL=1 start_mihomo || {
        enter_direct_mode "автозапуск Mihomo завершился ошибкой"
        return 1
    }
    say "Автозапуск Mihomo после reboot завершён"
    return 0
}

prepend_path(){
    d="$1"
    [ -n "$d" ] || return 0
    case ":$PATH:" in
        *":$d:"*) ;;
        *) PATH="$d:$PATH"; export PATH;;
    esac
}

find_nano(){
    if have nano; then
        which nano
        return 0
    fi

    for p in \
        /opt/bin/nano \
        /tmp/opt/bin/nano \
        "$USB_MOUNT/asusware.arm/bin/nano" \
        "$USB_MOUNT/asusware.arm/opt/bin/nano" \
        "$USB_MOUNT/asusware.arm/usr/bin/nano"; do
        if [ -x "$p" ]; then
            prepend_path "${p%/*}"
            printf '%s\n' "$p"
            return 0
        fi
    done

    if [ -d "$USB_MOUNT/asusware.arm" ]; then
        p="$(find "$USB_MOUNT/asusware.arm" -type f -name nano 2>/dev/null | head -n 1)"
        if [ -n "$p" ] && [ -x "$p" ]; then
            prepend_path "${p%/*}"
            printf '%s\n' "$p"
            return 0
        fi
    fi

    return 1
}


find_editor(){
    requested="${EDITOR:-}"
    if [ -n "$requested" ]; then
        case "$requested" in
            */*) [ -x "$requested" ] && { printf '%s\n' "$requested"; return 0; };;
            *) have "$requested" && { which "$requested"; return 0; };;
        esac
    fi

    nano_bin="$(find_nano)"
    [ -n "$nano_bin" ] && [ -x "$nano_bin" ] && { printf '%s\n' "$nano_bin"; return 0; }

    for x in mcedit vi; do
        have "$x" && { which "$x"; return 0; }
    done
    return 1
}

edit_config(){
    write_default_config || return 1
    editor_bin="$(find_editor)" || {
        fail "Текстовый редактор не найден. Передай config.yaml через scp или установи редактор вручную."
        return 1
    }
    say "Редактор: $editor_bin"
    "$editor_bin" "$CONFIG"
}

restore_config(){
    f="${1:-}"; [ -n "$f" ] || f="$(ls -1t "$BACKUPS"/config-*.yaml 2>/dev/null | head -n 1)"
    [ -f "$f" ] || { fail "Резервная копия не найдена"; return 1; }; cp "$f" "$CONFIG" || return 1; apply_config
}

install_all(){
    ensure_dirs || return 1
    [ -x "$ROUTE_HELPER" ] || { fail "Не установлен $ROUTE_HELPER"; return 1; }
    write_default_config || return 1
    install_core || { fail "Установка Mihomo не завершена"; return 1; }
    install_ui || { fail "Установка Zashboard не завершена"; return 1; }
    install_hooks || return 1
    choose_tun_device || return 1

    candidate="$BASE/run/runtime.install.yaml"
    rm -f "$candidate"
    render_runtime "$candidate" || return 1
    say "Проверяю подготовленный runtime.yaml"
    check_file "$candidate" || { rm -f "$candidate"; return 1; }
    mv -f "$candidate" "$RUNTIME" || return 1

    enter_direct_mode "чистая установка завершена; после первого apply VPN будет автоматически запускаться при reboot"
    say "Установка завершена в безопасном DIRECT-режиме"
    say "Замени config.yaml и выполни: goshacrash apply. Следующие reboot будут запускать Mihomo автоматически."
    status
}
update_all(){
    stop_mihomo >/dev/null 2>&1 || true
    install_core || return 1
    install_ui || return 1
    apply_config
}

# -----------------------------------------------------------------------------
# Router runtime defaults.
# Mihomo creates a userspace gVisor TUN with the conventional fixed name tun0.
# A separate helper creates old-kernel-compatible MARK/ip-rule/ip-route rules.
# -----------------------------------------------------------------------------

write_default_config(){
    [ -f "$CONFIG" ] && return 0
    ensure_dirs || return 1
    router_ip="$(lan_ip)"
    cat > "$CONFIG" <<CFG
# Личный config.yaml. Обновление GoshaCrash этот файл не заменяет.
# На роутере dnsmasq слушает :53, а GoshaCrash меняет DNS listener только
# в runtime.yaml на 127.0.0.1:1053.

allow-lan: true
bind-address: "*"
mode: rule
log-level: info
ipv6: false
find-process-mode: off

external-controller: 0.0.0.0:9090
secret: "CHANGE_ME"
external-ui: ui

profile:
  store-selected: true
  store-fake-ip: true

hosts:
  "www.asusrouter.com": $router_ip
  "router.asus.com": $router_ip

dns:
  enable: true
  listen: 127.0.0.1:1053
  ipv6: false
  prefer-h3: false
  use-hosts: true
  use-system-hosts: false
  respect-rules: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-filter:
    - "+.lan"
    - "+.local"
    - "+.arpa"
    - "localhost"

  # DNS только для автоматически созданного тестового конфига.
  default-nameserver:
    - 1.1.1.1
    - 9.9.9.9
  proxy-server-nameserver:
    - 1.1.1.1
    - 9.9.9.9

  nameserver:
    - "https://1.1.1.1/dns-query#GLOBAL-PROXY"
    - "https://8.8.8.8/dns-query#GLOBAL-PROXY"
  direct-nameserver:
    - 1.1.1.1
    - 9.9.9.9

tun:
  enable: true
  stack: gvisor
  device: tun0
  mtu: 1500
  dns-hijack:
    - "any:53"
    - "tcp://any:53"
  auto-route: false
  auto-redirect: false
  auto-detect-interface: false
  strict-route: false

proxies: []

proxy-groups:
  - name: GLOBAL-PROXY
    type: select
    proxies:
      - DIRECT

rules:
  - MATCH,DIRECT
CFG
    chmod 600 "$CONFIG" 2>/dev/null || true
    say "Создан $CONFIG"
}

watchdog_pid(){
    [ -f "$WATCHDOG_PIDFILE" ] || return 1
    p="$(cat "$WATCHDOG_PIDFILE" 2>/dev/null)"
    case "$p" in ''|*[!0-9]*) return 1;; esac
    kill -0 "$p" 2>/dev/null || return 1

    if [ -r "/proc/$p/cmdline" ]; then
        tr '\000' ' ' < "/proc/$p/cmdline" 2>/dev/null |
            grep -q 'watchdog-loop' || return 1
    fi

    printf '%s\n' "$p"
}

watchdog_log(){
    ensure_dirs >/dev/null 2>&1 || true

    if [ -f "$WATCHDOG_LOG" ]; then
        size="$(wc -c < "$WATCHDOG_LOG" 2>/dev/null)"
        case "$size" in ''|*[!0-9]*) size=0;; esac
        [ "$size" -le 262144 ] ||
            mv -f "$WATCHDOG_LOG" "$WATCHDOG_LOG.previous"
    fi

    stamp="$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null)"
    [ -n "$stamp" ] || stamp="unknown-time"
    printf '%s %s\n' "$stamp" "$*" >> "$WATCHDOG_LOG"
}

watchdog_stop(){
    if p="$(watchdog_pid)"; then
        kill "$p" 2>/dev/null || true
        n=0
        while kill -0 "$p" 2>/dev/null && [ "$n" -lt 5 ]; do
            sleep 1
            n=$((n + 1))
        done
        kill -0 "$p" 2>/dev/null && kill -9 "$p" 2>/dev/null || true
    fi
    rm -f "$WATCHDOG_PIDFILE"
}

watchdog_start(){
    watchdog_pid >/dev/null 2>&1 && return 0
    ensure_dirs || return 1
    [ -x "$BASE/goshacrash" ] || return 1

    if have nohup; then
        GOSHACRASH_BASE="$BASE" nohup "$BASE/goshacrash" watchdog-loop \
            </dev/null >> "$WATCHDOG_LOG" 2>&1 &
    else
        GOSHACRASH_BASE="$BASE" "$BASE/goshacrash" watchdog-loop \
            </dev/null >> "$WATCHDOG_LOG" 2>&1 &
    fi

    p=$!
    echo "$p" > "$WATCHDOG_PIDFILE"
    sleep 1
    kill -0 "$p" 2>/dev/null || {
        rm -f "$WATCHDOG_PIDFILE"
        warn "WAN watchdog не запустился"
        return 1
    }

    say "WAN watchdog запущен, PID=$p"
}

watchdog_wan_iface(){
    iface="$(nvram get wan0_ifname 2>/dev/null)"
    [ -n "$iface" ] || iface="$(nvram get wan_ifname 2>/dev/null)"
    [ -n "$iface" ] || iface="$(ip route show default 2>/dev/null | awk -v d="$TUN_DEVICE" '$0 !~ ("dev " d "([[:space:]]|$)") {for(i=1;i<=NF;i++) if($i=="dev"){print $(i+1); exit}}')"
    [ -n "$iface" ] && printf '%s\n' "$iface"
}

watchdog_wan_carrier_present(){
    iface="$(watchdog_wan_iface)"
    [ -n "$iface" ] || return 1

    carrier="/sys/class/net/$iface/carrier"
    if [ -r "$carrier" ]; then
        [ "$(cat "$carrier" 2>/dev/null)" = 1 ]
        return $?
    fi

    ip link show "$iface" 2>/dev/null | grep -q 'LOWER_UP'
}

watchdog_wan_route_present(){
    if ip route show 2>/dev/null | awk -v d="$TUN_DEVICE" '
        $1 == "default" && $0 !~ ("dev " d "([[:space:]]|$)") {found=1}
        END {exit(found ? 0 : 1)}
    '; then
        return 0
    fi

    route -n 2>/dev/null | awk -v d="$TUN_DEVICE" '
        $1 == "0.0.0.0" && $8 != d {found=1}
        END {exit(found ? 0 : 1)}
    '
}

watchdog_wan_available(){
    watchdog_wan_carrier_present && watchdog_wan_route_present
}

watchdog_probe_url(){
    url="$1"
    tmp="/tmp/goshacrash-watchdog.$$"
    probe_home="$STATE/watchdog-wget-home"
    mkdir -p "$probe_home" 2>/dev/null || true
    chmod 700 "$probe_home" 2>/dev/null || true
    rm -f "$tmp"
    rc=1

    if [ -x /usr/sbin/wget ]; then
        HOME="$probe_home" /usr/sbin/wget -T 15 -t 1 --no-check-certificate \
            -O "$tmp" "$url" >/dev/null 2>&1 && rc=0
    elif have wget; then
        HOME="$probe_home" "$(which wget)" -T 15 -t 1 --no-check-certificate \
            -O "$tmp" "$url" >/dev/null 2>&1 && rc=0
    fi

    if [ "$rc" -ne 0 ] && have curl; then
        HOME="$probe_home" "$(which curl)" -4 -k -f -L \
            --connect-timeout 10 --max-time 20 -o "$tmp" "$url" >/dev/null 2>&1 && rc=0
    fi

    rm -f "$tmp"
    return "$rc"
}

watchdog_internet_ok(){
    for url in $WATCHDOG_URLS; do
        watchdog_probe_url "$url" && return 0
    done
    return 1
}

watchdog_local_ok(){
    running_pid >/dev/null 2>&1 || return 1
    netstat -ln 2>/dev/null | grep -Eq "[:.]$DNS_PORT[[:space:]]" || return 1

    d="$(tun_device)"
    ip link show "$d" >/dev/null 2>&1 ||
        ifconfig "$d" >/dev/null 2>&1 || return 1

    route_helper status >/dev/null 2>&1 || return 1
    return 0
}

watchdog_fail_open(){
    reason="$1"
    enter_direct_mode "$reason"
    watchdog_log "Watchdog завершён; VPN останется выключенным до ручного start или следующего reboot"
}

watchdog_loop(){
    cleanup_watchdog(){
        saved="$(cat "$WATCHDOG_PIDFILE" 2>/dev/null)"
        [ "$saved" = "$$" ] && rm -f "$WATCHDOG_PIDFILE"
    }

    trap 'cleanup_watchdog; exit 0' TERM INT HUP
    trap 'cleanup_watchdog' EXIT
    echo "$$" > "$WATCHDOG_PIDFILE"

    watchdog_log "Fail-open watchdog запущен: tick=${WATCHDOG_INTERVAL}s local-threshold=$WATCHDOG_LOCAL_FAIL_THRESHOLD remote-probe=$WATCHDOG_PROBE_ENABLED"

    slept=0
    while [ "$slept" -lt "$WATCHDOG_BOOT_GRACE" ]; do
        sleep 2
        slept=$((slept + 2))
    done

    local_failures=0
    internet_failures=0
    probe_elapsed=0

    while :; do
        if ! watchdog_wan_available; then
            watchdog_fail_open "WAN-кабель, carrier или основной default route потерян"
            return 0
        fi

        if watchdog_local_ok; then
            local_failures=0
        else
            local_failures=$((local_failures + 1))
            watchdog_log "Локальная проверка Mihomo/TUN/routing не прошла ($local_failures/$WATCHDOG_LOCAL_FAIL_THRESHOLD)"

            if [ "$local_failures" -ge "$WATCHDOG_LOCAL_FAIL_THRESHOLD" ]; then
                watchdog_fail_open "Mihomo, DNS, TUN или policy routing перестали работать"
                return 0
            fi
        fi

        if [ "$WATCHDOG_PROBE_ENABLED" = 1 ]; then
            probe_elapsed=$((probe_elapsed + WATCHDOG_INTERVAL))
            if [ "$probe_elapsed" -ge "$WATCHDOG_PROBE_INTERVAL" ]; then
                probe_elapsed=0

                if watchdog_internet_ok; then
                    internet_failures=0
                else
                    internet_failures=$((internet_failures + 1))
                    watchdog_log "Контрольный интернет-запрос не прошёл ($internet_failures/$WATCHDOG_FAIL_THRESHOLD)"

                    if [ "$internet_failures" -ge "$WATCHDOG_FAIL_THRESHOLD" ]; then
                        watchdog_fail_open "WAN присутствует, но интернет через Mihomo недоступен"
                        return 0
                    fi
                fi
            fi
        fi

        sleep "$WATCHDOG_INTERVAL"
    done
}

watchdog_status(){
    if p="$(watchdog_pid)"; then
        echo "WAN watchdog: работает, PID=$p"
    else
        echo "WAN watchdog: не запущен"
    fi

    echo "Fail-open: tick=${WATCHDOG_INTERVAL}s; local-threshold=$WATCHDOG_LOCAL_FAIL_THRESHOLD; remote-probe=$WATCHDOG_PROBE_ENABLED"
    [ "$WATCHDOG_PROBE_ENABLED" = 1 ] && echo "Probe URLs: $WATCHDOG_URLS"
    [ "$WATCHDOG_PROBE_ENABLED" = 1 ] && echo "Remote probe: interval=${WATCHDOG_PROBE_INTERVAL}s; threshold=$WATCHDOG_FAIL_THRESHOLD"
    if [ -f "$WATCHDOG_LOG" ]; then
        echo "Последние события:"
        tail -n 12 "$WATCHDOG_LOG" 2>/dev/null
    fi
}

dns_status(){
    dnsmasq_ok=no
    mihomo_ok=no
    bridge=off
    netstat -ln 2>/dev/null | grep -Eq '[:.]53[[:space:]]' && dnsmasq_ok=yes
    netstat -ln 2>/dev/null | grep -Eq "[:.]$DNS_PORT[[:space:]]" && mihomo_ok=yes
    [ -f "$VPN_SESSION_FILE" ] && running_pid >/dev/null 2>&1 && bridge=on
    echo "dnsmasq:53=$dnsmasq_ok; Mihomo DNS:$DNS_PORT=$mihomo_ok; bridge=$bridge"
}

firewall_reload(){
    running_pid >/dev/null 2>&1 || return 0
    say "ASUSWRT перезапустил firewall; пересоздаю совместимые правила"
    route_helper reload || {
        enter_direct_mode "не удалось восстановить правила после перезапуска firewall"
        return 1
    }
}

status(){
    if p="$(running_pid)"; then
        echo "Mihomo: работает, PID=$p"
    else
        echo "Mihomo: не запущен"
    fi
    echo "GoshaCrash: $VERSION"
    if [ -f "$VPN_SESSION_FILE" ] && running_pid >/dev/null 2>&1; then
        echo "Сеанс: VPN активен; после reboot запускается автоматически"
        echo "Режим: чистый TUN, TCP+UDP через gVisor"
    else
        echo "Сеанс: обычный DIRECT; ручной start или reboot снова включит VPN"
        [ -f "$DIRECT_REASON_FILE" ] && echo "Причина DIRECT: $(cat "$DIRECT_REASON_FILE" 2>/dev/null)"
        echo "Режим VPN: чистый TUN, TCP+UDP через gVisor"
    fi
    echo "BASE: $BASE"
    echo "DNS: $(dns_status)"

    d="$(tun_device)"
    if ip link show "$d" >/dev/null 2>&1 || ifconfig "$d" >/dev/null 2>&1; then
        echo "TUN: $d работает"
    else
        echo "TUN: $d не найден"
    fi

    echo "Mihomo: auto-route=false; auto-redirect=false"
    if [ -f "$VPN_SESSION_FILE" ] && running_pid >/dev/null 2>&1; then
        if route_helper status >/dev/null 2>&1; then
            echo "GoshaRoute: работает"
        else
            echo "GoshaRoute: ОШИБКА"
        fi
    else
        echo "GoshaRoute: выключен (норма для DIRECT)"
    fi
    echo "LAN: TCP+UDP -> MARK $TUN_MARK -> table $TUN_TABLE -> $d -> gVisor"
    [ "$ROUTE_ROUTER" = 1 ] &&
        echo "Роутер: TCP+UDP -> TUN; исходящие сокеты Mihomo обходят петлю mark=$OUTBOUND_MARK_HEX"

    if p="$(watchdog_pid)"; then
        echo "WAN watchdog: работает, PID=$p"
    else
        echo "WAN watchdog: не запущен"
    fi

    if running_pid >/dev/null 2>&1; then
        c="$(yaml_top "$RUNTIME" external-controller)"
        [ -n "$c" ] || c=0.0.0.0:9090
        p="${c##*:}"
        case "$p" in ''|*[!0-9]*) p=9090;; esac
        echo "Zashboard: http://$(lan_ip):$p/ui/"
        s="$(yaml_top "$RUNTIME" secret)"
        [ -n "$s" ] && echo "API secret: $s"
    else
        echo "Zashboard: недоступен до запуска VPN"
    fi
}

doctor(){
    echo "=== GoshaCrash doctor ==="
    echo "BASE=$BASE"
    echo "USB=$USB_MOUNT"
    echo "ARCH=$(uname -m)"
    echo "LAN=$(lan_ifaces)"
    echo "IP=$(lan_ip)"
    echo

    [ -x "$BIN" ] && "$BIN" -v || echo "Mihomo: NOT FOUND"
    [ -x "$BIN" ] && "$BIN" -v 2>&1 | grep -Fq 'Use tags: with_gvisor' &&
        echo "gVisor build tag: OK" || echo "gVisor build tag: MISSING"
    [ -x "$ROUTE_HELPER" ] && "$ROUTE_HELPER" version || echo "GoshaRoute: NOT FOUND"
    [ -c /dev/net/tun ] && echo "/dev/net/tun: OK" || echo "/dev/net/tun: NOT FOUND"
    echo
    status
    echo

    echo "=== runtime tun ==="
    extract_yaml_section "$RUNTIME" tun /tmp/goshacrash-doctor-tun.$$
    cat /tmp/goshacrash-doctor-tun.$$ 2>/dev/null
    rm -f /tmp/goshacrash-doctor-tun.$$
    echo

    echo "=== compatible routing ==="
    route_helper doctor || true
    echo

    echo "=== mihomo log ==="
    tail -n 100 "$LOGFILE" 2>/dev/null || true
}

pause_menu(){ printf '\nНажми Enter для продолжения...'; read _dummy; }

menu(){
    while :; do
        printf '\033[2J\033[H'
        echo '========================================'
        echo "      GoshaCrash $VERSION"
        echo '========================================'
        if p="$(running_pid)"; then
            echo "Mihomo: работает, PID=$p"
        else
            echo "Mihomo: не запущен"
        fi
        if p="$(watchdog_pid)"; then
            echo "Watchdog: работает, PID=$p"
        else
            echo "Watchdog: не запущен"
        fi
        echo
        echo '1) Запустить VPN'
        echo '2) Остановить VPN и перейти в DIRECT'
        echo '3) Перезапустить VPN'
        echo '4) Редактировать config.yaml и применить'
        echo '5) Применить config.yaml'
        echo '6) Показать адрес Zashboard'
        echo '7) Обновить gVisor Mihomo и Zashboard'
        echo '0) Выход'
        echo '========================================'
        printf 'Выбери пункт: '
        read choice
        case "$choice" in
            1) start_mihomo;;
            2) stop_mihomo;;
            3) stop_mihomo; start_mihomo;;
            4) edit_config && apply_config;;
            5) apply_config;;
            6) c="$(yaml_top "$RUNTIME" external-controller)"; [ -n "$c" ] || c=0.0.0.0:9090; p="${c##*:}"; p="$(echo "$p"|sed 's/[^0-9].*$//')"; echo "http://$(lan_ip):${p:-9090}/ui/";;
            7) update_all;;
            0) return 0;;
            *) echo 'Неизвестный пункт';;
        esac
        pause_menu
    done
}

usage(){ cat <<'USAGE'
GoshaCrash 1.1.0

Политика работы:
  - после reboot S99goshacrash ждёт WAN и автоматически запускает Mihomo;
  - используется один обычный TUN-интерфейс tun0;
  - WAN/link loss, crash Mihomo/TUN/routing или длительный провал
    всех интернет-проверок переводит сеть в штатный DIRECT;
  - после fail-open VPN включается вручную либо при следующем reboot;
  - интернет проверяется по ya.ru, mail.ru и rambler.ru; достаточно одного ответа.

Управление:
  goshacrash                 открыть меню
  goshacrash start           запустить VPN
  goshacrash stop            остановить VPN и перейти в DIRECT
  goshacrash direct          то же, что stop
  goshacrash restart         перезапустить VPN
  goshacrash edit            изменить config.yaml и применить
  goshacrash apply           применить config.yaml и запустить VPN
  goshacrash status          показать состояние
  goshacrash ui              показать адрес Zashboard
  goshacrash update          обновить Mihomo и Zashboard
  goshacrash watchdog-status состояние watchdog
  goshacrash runtime-audit   показать runtime TUN
  goshacrash route-status    состояние iptables/ip rule/ip route
USAGE
}


ensure_dirs >/dev/null 2>&1 || true
load_tun_device
case "${1:-menu}" in
 menu) menu;;
 start) start_mihomo;;
 stop|direct) stop_mihomo;;
 restart) stop_mihomo; start_mihomo;;
 edit|setup) edit_config && apply_config;;
 apply) apply_config;;
 status) status;;
 ui) c="$(yaml_top "$RUNTIME" external-controller)"; [ -n "$c" ] || c=0.0.0.0:9090; p="${c##*:}"; p="$(echo "$p"|sed 's/[^0-9].*$//')"; echo "http://$(lan_ip):${p:-9090}/ui/";;
 update) update_all;;
 watchdog-status) watchdog_status;;
 runtime-audit) runtime_audit;;
 runtime-render) runtime_render_only;;
 route-status) route_helper status;;
 route-reload) route_helper reload;;
 help|-h|--help) usage;;

 # Служебные команды — не показываются в пользовательском меню.
 install) install_all;;
 check) check_config;;
 doctor) doctor;;
 logs) tail -n "${2:-100}" "$LOGFILE" 2>/dev/null || true;;
 backup) backup_config;;
 restore) restore_config "${2:-}";;
 install-hooks) install_hooks;;
 uninstall-hooks) uninstall_hooks;;
 boot) boot_service;;
 firewall-reload) firewall_reload;;
 watchdog-loop) watchdog_loop;;
 version) echo "$VERSION";;

 *) usage; exit 1;;
esac
