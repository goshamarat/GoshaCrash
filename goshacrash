choose_language() {
  while true; do
    banner
    small_header "Language"

    say "Current: $GC_LANG"
    say ""
    say "  1) Русский"
    say "  2) English"
    say "  3) 中文"
    say ""
    say "  0) Back"
    say ""
    print "$(t choose)"

    IFS= read -r choice

    case "$choice" in
      1|ru|RU) save_lang ru; badge_ok "Language saved: ru"; pause; return ;;
      2|en|EN) save_lang en; badge_ok "Language saved: en"; pause; return ;;
      3|zh|ZH|cn|CN) save_lang zh; badge_ok "Language saved: zh"; pause; return ;;
      0|q|Q) return ;;
      *) badge_warn "$(t unknown): $choice"; pause ;;
    esac
  done
}

