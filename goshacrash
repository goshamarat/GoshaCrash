    main_menu
    ;;
  quick)
    quick_setup
    ;;
  init)
    init_files
    ;;
  edit-settings)
    open_editor "$ENV_FILE"
    ;;
  edit-dns)
    open_editor "$DNS_FILE"
    ;;
  edit-profile)
    open_editor "$PROFILE_FILE"
    ;;
  gen-config)
    generate_config
    ;;
  show-config)
    show_config
    ;;
  install-core|update-core)
    install_core
    ;;
  core-version)
    core_version
    ;;
  install-ui|update-ui)
    install_ui
    ;;
  dashboard)
    header "$(msg dashboard_url)"
    dashboard_url
    say "UI path: $UI_DIR"
    ;;
  test)
    test_config
    ;;
  start)
    start_core
    ;;
  stop)
    stop_core
    ;;
  restart)
    restart_core
    ;;
  status)
    status_core
    ;;
  logs)
    logs_core "$2"
    ;;
  doctor)
    doctor
    ;;
  install-deps)
    install_deps
    ;;
  install-editor)
    install_editor
    ;;
  paths)
    show_paths
    ;;
  lang|language)
    language_menu
    ;;
  set-lang)
    save_language "$2"
    say "$(msg lang_saved): $2"
    ;;
  version|-v|--version)
    say "$APP_BIN $APP_VERSION"
    ;;
  help|-h|--help)
    show_help
    ;;
  *)
    die "unknown command: $1"
    ;;
esac
