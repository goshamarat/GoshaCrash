#!/bin/sh

APP_NAME="GoshaCrash"
APP_BIN="goshacrash"
APP_VERSION="0.3.0-dev"

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" 2>/dev/null && pwd)"

BASE_DIR="${BASE_DIR:-$HOME/goshacrash-lab}"

BIN_DIR="$BASE_DIR/bin"
CONFIG_DIR="$BASE_DIR/config"
UI_DIR="$BASE_DIR/ui"
RULESET_DIR="$BASE_DIR/ruleset"
LOG_DIR="$BASE_DIR/logs"
RUN_DIR="$BASE_DIR/run"
TMP_DIR="$BASE_DIR/tmp"

CUSTOM_DIR="${CUSTOM_DIR:-$SCRIPT_DIR/custom}"
TEMPLATE_DIR="$SCRIPT_DIR/templates"
BACKUP_DIR="$CUSTOM_DIR/backups"

ENV_FILE="$CUSTOM_DIR/env.conf"
DNS_FILE="$CUSTOM_DIR/dns.yaml"
CUSTOM_CONFIG_FILE="$CUSTOM_DIR/config.yaml"
TARGET_CONFIG_FILE="$CONFIG_DIR/config.yaml"

LANG_FILE="$BASE_DIR/lang"
MIHOMO_BIN="$BIN_DIR/mihomo"
MIHOMO_PID_FILE="$RUN_DIR/mihomo.pid"
MIHOMO_LOG_FILE="$LOG_DIR/mihomo.log"

MIHOMO_MIXED_PORT="${MIHOMO_MIXED_PORT:-7890}"
MIHOMO_API_HOST="${MIHOMO_API_HOST:-127.0.0.1}"
MIHOMO_API_PORT="${MIHOMO_API_PORT:-9090}"
MIHOMO_DNS_HOST="${MIHOMO_DNS_HOST:-127.0.0.1}"
MIHOMO_DNS_PORT="${MIHOMO_DNS_PORT:-1053}"
MIHOMO_SECRET="${MIHOMO_SECRET:-changeme}"

GC_MODE="${GC_MODE:-wsl}"
GC_EDITOR="${GC_EDITOR:-auto}"
GC_LANG="${GC_LANG:-}"

MIHOMO_REPO_OWNER="${MIHOMO_REPO_OWNER:-MetaCubeX}"
MIHOMO_REPO_NAME="${MIHOMO_REPO_NAME:-mihomo}"
ZASHBOARD_REPO_OWNER="${ZASHBOARD_REPO_OWNER:-Zephyruso}"
ZASHBOARD_REPO_NAME="${ZASHBOARD_REPO_NAME:-zashboard}"

color_init() {
  if [ -t 1 ] && [ -z "$NO_COLOR" ]; then
    ESC="$(printf '\033')"
    RESET="${ESC}[0m"
    BOLD="${ESC}[1m"
    DIM="${ESC}[2m"
    RED="${ESC}[31m"
    GREEN="${ESC}[32m"
    YELLOW="${ESC}[33m"
    CYAN="${ESC}[36m"
  else
    RESET=""
    BOLD=""
    DIM=""
    RED=""
    GREEN=""
    YELLOW=""
    CYAN=""
  fi
}

say() {
  printf '%s\n' "$*"
}

print() {
  printf '%s' "$*"
}

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

die() {
  say "${RED}ERROR:${RESET} $*" >&2
  exit 1
}

run_as_root() {
  if [ "$(id -u 2>/dev/null)" = "0" ]; then
    "$@"
  elif has_cmd sudo; then
    sudo "$@"
  else
    die "Need root privileges. Install sudo or run as root."
  fi
}

download() {
  out="$1"
  url="$2"

  [ -n "$out" ] || die "download: output file is empty"
  [ -n "$url" ] || die "download: URL is empty"

  if has_cmd curl; then
    curl -fL --connect-timeout 20 --retry 2 -o "$out" "$url"
  elif has_cmd wget; then
    wget --timeout=20 --tries=2 --no-check-certificate -O "$out" "$url"
  else
    die "curl or wget is required"
  fi
}

load_lang() {
  if [ -n "$GC_LANG" ]; then
    case "$GC_LANG" in
      ru|en|zh) return 0 ;;
      *) GC_LANG="ru" ;;
    esac
  elif [ -f "$LANG_FILE" ]; then
    GC_LANG="$(cat "$LANG_FILE" 2>/dev/null | head -n 1)"
    case "$GC_LANG" in
      ru|en|zh) ;;
      *) GC_LANG="ru" ;;
    esac
  else
    GC_LANG="ru"
  fi
}

save_lang() {
  lang="$1"

  case "$lang" in
    ru|en|zh) ;;
    *) say "Unsupported language: $lang"; return 1 ;;
  esac

  mkdir -p "$BASE_DIR"
  printf '%s\n' "$lang" > "$LANG_FILE"
  GC_LANG="$lang"
}

t() {
  key="$1"

  case "$GC_LANG:$key" in
    ru:main_menu) say "Главное меню" ;;
    en:main_menu) say "Main menu" ;;
    zh:main_menu) say "主菜单" ;;

    ru:config_menu) say "Менеджер конфигов" ;;
    en:config_menu) say "Config manager" ;;
    zh:config_menu) say "配置管理器" ;;

    ru:core_menu) say "Mihomo Core" ;;
    en:core_menu) say "Mihomo Core" ;;
    zh:core_menu) say "Mihomo Core" ;;

    ru:editor_menu) say "Редактор" ;;
    en:editor_menu) say "Editor" ;;
    zh:editor_menu) say "编辑器" ;;

    ru:doctor) say "Диагностика" ;;
    en:doctor) say "Doctor" ;;
    zh:doctor) say "诊断" ;;

    ru:language) say "Язык" ;;
    en:language) say "Language" ;;
    zh:language) say "语言" ;;

    ru:exit) say "Выход" ;;
    en:exit) say "Exit" ;;
    zh:exit) say "退出" ;;

    ru:back) say "Назад" ;;
    en:back) say "Back" ;;
    zh:back) say "返回" ;;

    ru:choose) say "Выбери пункт: " ;;
    en:choose) say "Choose option: " ;;
    zh:choose) say "请选择: " ;;

    ru:unknown) say "Неизвестный пункт" ;;
    en:unknown) say "Unknown option" ;;
    zh:unknown) say "未知选项" ;;

    ru:press_enter) say "Нажми Enter, чтобы продолжить..." ;;
    en:press_enter) say "Press Enter to continue..." ;;
    zh:press_enter) say "按 Enter 继续..." ;;

    ru:bye) say "Пока." ;;
    en:bye) say "Bye." ;;
    zh:bye) say "再见。" ;;

    *)
      say "$key"
      ;;
  esac
}

term_width() {
  cols="${COLUMNS:-}"

  if [ -z "$cols" ] && has_cmd stty; then
    cols="$(stty size 2>/dev/null | awk '{print $2}' 2>/dev/null)"
  fi

  case "$cols" in
    ''|*[!0-9]*) cols=72 ;;
  esac

  [ "$cols" -lt 60 ] && cols=60
  [ "$cols" -gt 100 ] && cols=100

  say "$cols"
}

repeat_char() {
  char="$1"
  count="$2"
  i=0

  while [ "$i" -lt "$count" ]; do
    print "$char"
    i=$((i + 1))
  done

  say ""
}

hr() {
  char="${1:-─}"
  repeat_char "$char" "$(term_width)"
}

clear_screen() {
  if has_cmd clear; then
    clear
  else
    printf '\033c'
  fi
}

pause() {
  say ""
  print "${DIM}$(t press_enter)${RESET}"
  IFS= read -r _
}

badge_ok() {
  printf '%s[ OK ]%s %s\n' "$GREEN" "$RESET" "$*"
}

badge_no() {
  printf '%s[ NO ]%s %s\n' "$RED" "$RESET" "$*"
}

badge_warn() {
  printf '%s[WARN]%s %s\n' "$YELLOW" "$RESET" "$*"
}

badge_info() {
  printf '%s[INFO]%s %s\n' "$CYAN" "$RESET" "$*"
}

banner() {
  clear_screen
  say "${CYAN}"
  say "   ______           __          ______               __  "
  say "  / ____/___  _____/ /_  ____ _/ ____/________ _____/ /_ "
  say " / / __/ __ \/ ___/ __ \/ __ \`/ /   / ___/ __ \`/ ___/ __ \\"
  say "/ /_/ / /_/ (__  ) / / / /_/ / /___/ /  / /_/ (__  ) / / /"
  say "\\____/\\____/____/_/ /_/\\__,_/\\____/_/   \\__,_/____/_/ /_/ "
  say "${RESET}"
  say " ${BOLD}${APP_NAME}${RESET} ${DIM}${APP_VERSION}${RESET}"
  say " ${DIM}Mihomo + Zashboard installer/controller${RESET}"
  say " ${DIM}Language: ${GC_LANG}${RESET}"
  hr "─"
}

small_header() {
  say ""
  say "${BOLD}${CYAN}$1${RESET}"
  hr "─"
}

detect_target() {
  if has_cmd ipkg; then
    say "asus-optware"
  elif has_cmd opkg; then
    say "asus-entware"
  elif [ -d /jffs ] || [ -d /tmp/mnt ] || [ -d /opt ]; then
    say "asus"
  elif grep -qi microsoft /proc/version 2>/dev/null; then
    say "wsl"
  else
    say "linux"
  fi
}

detect_arch() {
  uname -m 2>/dev/null || say "unknown"
}

load_env() {
  if [ -f "$ENV_FILE" ]; then
    . "$ENV_FILE"
  fi
}

init_dirs() {
  mkdir -p "$BIN_DIR" "$CONFIG_DIR" "$UI_DIR" "$RULESET_DIR" "$LOG_DIR" "$RUN_DIR" "$TMP_DIR"
  mkdir -p "$CUSTOM_DIR" "$BACKUP_DIR"
}

copy_template_or_create() {
  template="$1"
  target="$2"
  fallback="$3"

  if [ -f "$target" ]; then
    return 0
  fi

  if [ -f "$template" ]; then
    cp "$template" "$target"
  else
    eval "$fallback"
  fi
}

create_default_env() {
  cat > "$ENV_FILE" <<'EOF'
# GoshaCrash user settings
# This file is shell-compatible.

MIHOMO_MIXED_PORT=7890
MIHOMO_API_HOST=127.0.0.1
MIHOMO_API_PORT=9090
MIHOMO_DNS_HOST=127.0.0.1
MIHOMO_DNS_PORT=1053
MIHOMO_SECRET=changeme

GC_MODE=wsl
GC_EDITOR=auto

MIHOMO_PATTERN=

MIHOMO_REPO_OWNER=MetaCubeX
MIHOMO_REPO_NAME=mihomo

ZASHBOARD_REPO_OWNER=Zephyruso
ZASHBOARD_REPO_NAME=zashboard
EOF
}

create_default_dns() {
  cat > "$DNS_FILE" <<'EOF'
dns:
  enable: true
  listen: 127.0.0.1:1053
  ipv6: false
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16

  default-nameserver:
    - 1.1.1.1
    - 8.8.8.8

  nameserver:
    - https://1.1.1.1/dns-query
    - https://8.8.8.8/dns-query

  proxy-server-nameserver:
    - https://1.1.1.1/dns-query

  direct-nameserver:
    - 1.1.1.1
    - 8.8.8.8

  fake-ip-filter:
    - "*.lan"
    - "*.local"
    - "localhost"
    - "router.asus.com"
    - "+.asuscomm.com"
EOF
}

create_default_config() {
  cat > "$CUSTOM_CONFIG_FILE" <<'EOF'
profile:
  store-selected: true
  store-fake-ip: true

proxies: []

proxy-groups:
  - name: PROXY
    type: select
    proxies:
      - DIRECT

rules:
  - DOMAIN-SUFFIX,lan,DIRECT
  - DOMAIN-SUFFIX,local,DIRECT
  - DOMAIN,localhost,DIRECT
  - IP-CIDR,127.0.0.0/8,DIRECT,no-resolve
  - IP-CIDR,10.0.0.0/8,DIRECT,no-resolve
  - IP-CIDR,172.16.0.0/12,DIRECT,no-resolve
  - IP-CIDR,192.168.0.0/16,DIRECT,no-resolve
  - MATCH,DIRECT
EOF
}

ensure_custom_files() {
  init_dirs

  copy_template_or_create "$TEMPLATE_DIR/env.conf" "$ENV_FILE" "create_default_env"
  copy_template_or_create "$TEMPLATE_DIR/dns.yaml" "$DNS_FILE" "create_default_dns"
  copy_template_or_create "$TEMPLATE_DIR/config.yaml" "$CUSTOM_CONFIG_FILE" "create_default_config"
}

init_custom() {
  ensure_custom_files
  load_env

  banner
  small_header "Custom files"
  badge_ok "$ENV_FILE"
  badge_ok "$DNS_FILE"
  badge_ok "$CUSTOM_CONFIG_FILE"
}

detect_editor() {
  load_env

  if [ "$GC_EDITOR" != "auto" ] && [ -n "$GC_EDITOR" ]; then
    if has_cmd "$GC_EDITOR"; then
      say "$GC_EDITOR"
      return 0
    fi
  fi

  if [ -n "$EDITOR" ] && has_cmd "$EDITOR"; then
    say "$EDITOR"
    return 0
  fi

  if has_cmd nano; then
    say "nano"
    return 0
  fi

  if has_cmd mcedit; then
    say "mcedit"
    return 0
  fi

  return 1
}

check_editor() {
  banner
  small_header "Editor"

  if editor_cmd="$(detect_editor 2>/dev/null)"; then
    badge_ok "Editor found: $editor_cmd"
    "$editor_cmd" --version 2>/dev/null | head -n 3 || true
  else
    badge_warn "Editor not found"
    say ""
    say "No vi fallback is used."
    say "Run:"
    say "  ./goshacrash install-editor"
  fi
}

install_editor() {
  banner
  small_header "Install nano"

  if has_cmd nano; then
    badge_ok "nano already installed: $(command -v nano)"
    return 0
  fi

  if has_cmd ipkg; then
    badge_info "Package manager: ipkg"
    ipkg update
    ipkg install nano
  elif has_cmd opkg; then
    badge_info "Package manager: opkg"
    opkg update
    opkg install nano-full || opkg install nano
  elif has_cmd apt-get; then
    badge_info "Package manager: apt-get"
    run_as_root apt-get update
    run_as_root apt-get install -y nano
  elif has_cmd apt; then
    badge_info "Package manager: apt"
    run_as_root apt update
    run_as_root apt install -y nano
  else
    badge_no "No apt/opkg/ipkg found"
    return 1
  fi

  if has_cmd nano; then
    badge_ok "nano installed: $(command -v nano)"
  else
    badge_no "nano installation failed"
    return 1
  fi
}

open_editor() {
  file="$1"

  ensure_custom_files
  load_env

  [ -f "$file" ] || die "File not found: $file"

  if editor_cmd="$(detect_editor 2>/dev/null)"; then
    "$editor_cmd" "$file"
  else
    badge_warn "Editor not found"
    say "Run:"
    say "  ./goshacrash install-editor"
    return 1
  fi
}

show_file() {
  file="$1"
  title="$2"

  ensure_custom_files

  banner
  small_header "$title"

  if [ -f "$file" ]; then
    cat "$file"
  else
    badge_no "File not found: $file"
  fi
}

backup_config() {
  ensure_custom_files

  stamp="$(date +%Y%m%d-%H%M%S 2>/dev/null || date)"
  dst="$BACKUP_DIR/$stamp"
  mkdir -p "$dst"

  cp "$ENV_FILE" "$dst/env.conf" 2>/dev/null || true
  cp "$DNS_FILE" "$dst/dns.yaml" 2>/dev/null || true
  cp "$CUSTOM_CONFIG_FILE" "$dst/config.yaml" 2>/dev/null || true
  cp "$TARGET_CONFIG_FILE" "$dst/final-config.yaml" 2>/dev/null || true

  banner
  small_header "Backup"
  badge_ok "$dst"
}

generate_config() {
  ensure_custom_files
  load_env
  mkdir -p "$CONFIG_DIR"

  if [ -f "$TARGET_CONFIG_FILE" ]; then
    stamp="$(date +%Y%m%d-%H%M%S 2>/dev/null || date)"
    cp "$TARGET_CONFIG_FILE" "$TARGET_CONFIG_FILE.bak.$stamp" 2>/dev/null || true
  fi

  cat > "$TARGET_CONFIG_FILE" <<EOF
mixed-port: $MIHOMO_MIXED_PORT
allow-lan: false
bind-address: "127.0.0.1"

mode: rule
log-level: info
ipv6: false

external-controller: $MIHOMO_API_HOST:$MIHOMO_API_PORT
external-ui: $UI_DIR
secret: "$MIHOMO_SECRET"

EOF

  cat "$DNS_FILE" >> "$TARGET_CONFIG_FILE"
  printf '\n' >> "$TARGET_CONFIG_FILE"
  cat "$CUSTOM_CONFIG_FILE" >> "$TARGET_CONFIG_FILE"

  banner
  small_header "Generate config"
  badge_ok "$TARGET_CONFIG_FILE"
}

show_final_config() {
  banner
  small_header "Final Mihomo config"

  if [ -f "$TARGET_CONFIG_FILE" ]; then
    cat "$TARGET_CONFIG_FILE"
  else
    badge_warn "Final config not generated yet"
    say "Run:"
    say "  ./goshacrash gen-config"
  fi
}

release_api_url() {
  owner="$1"
  repo="$2"
  say "https://api.github.com/repos/$owner/$repo/releases/latest"
}

get_release_json() {
  owner="$1"
  repo="$2"
  out="$3"

  download "$out" "$(release_api_url "$owner" "$repo")"
}

list_release_assets() {
  json="$1"

  grep '"name":' "$json" 2>/dev/null \
    | sed 's/.*"name": "\(.*\)",*/\1/' \
    | sed 's/",*$//' || true
}

find_asset_url() {
  json="$1"
  patterns="$2"

  for pattern in $patterns; do
    url="$(grep '"browser_download_url":' "$json" 2>/dev/null \
      | grep -E "$pattern" \
      | sed 's/.*"browser_download_url": "\(.*\)".*/\1/' \
      | head -n 1)"

    if [ -n "$url" ]; then
      say "$url"
      return 0
    fi
  done

  return 1
}

detect_mihomo_patterns() {
  load_env

  if [ -n "$MIHOMO_PATTERN" ]; then
    say "$MIHOMO_PATTERN"
    return
  fi

  arch="$(detect_arch)"
  target="$(detect_target)"

  case "$arch" in
    x86_64|amd64)
      say 'mihomo-linux-amd64-v1-.*\.gz$ mihomo-linux-amd64-compatible-.*\.gz$ mihomo-linux-amd64-.*\.gz$'
      ;;
    aarch64|arm64)
      say 'mihomo-linux-arm64-.*\.gz$'
      ;;
    armv7l|armv7*)
      if [ "$target" = "asus-optware" ]; then
        say 'mihomo-linux-armv5-.*\.gz$ mihomo-linux-armv7-.*\.gz$ mihomo-linux-armv6-.*\.gz$'
      else
        say 'mihomo-linux-armv7-.*\.gz$ mihomo-linux-armv5-.*\.gz$'
      fi
      ;;
    armv6l|armv6*)
      say 'mihomo-linux-armv6-.*\.gz$ mihomo-linux-armv5-.*\.gz$'
      ;;
    armv5tel|armv5*)
      say 'mihomo-linux-armv5-.*\.gz$'
      ;;
    mipsle)
      say 'mihomo-linux-mipsle-softfloat-.*\.gz$ mihomo-linux-mipsle-.*\.gz$'
      ;;
    mips)
      say 'mihomo-linux-mips-softfloat-.*\.gz$ mihomo-linux-mips-.*\.gz$'
      ;;
    *)
      say 'mihomo-linux-amd64-v1-.*\.gz$'
      ;;
  esac
}

unpack_gzip_to() {
  src="$1"
  dst="$2"

  if has_cmd gzip; then
    gzip -dc "$src" > "$dst"
  elif has_cmd gunzip; then
    gunzip -c "$src" > "$dst"
  else
    die "gzip or gunzip is required"
  fi
}

install_core() {
  ensure_custom_files
  load_env
  init_dirs

  banner
  small_header "Install Mihomo core"

  release_json="$TMP_DIR/mihomo-release.json"
  patterns="$(detect_mihomo_patterns)"

  badge_info "Repo: $MIHOMO_REPO_OWNER/$MIHOMO_REPO_NAME"
  badge_info "Arch: $(detect_arch)"
  badge_info "Target: $(detect_target)"
  badge_info "Patterns: $patterns"

  get_release_json "$MIHOMO_REPO_OWNER" "$MIHOMO_REPO_NAME" "$release_json" || die "failed to fetch Mihomo release info"

  url="$(find_asset_url "$release_json" "$patterns")"

  if [ -z "$url" ]; then
    badge_no "No suitable Mihomo asset found"
    say ""
    say "Available assets:"
    list_release_assets "$release_json"
    return 1
  fi

  badge_info "Downloading:"
  say "$url"

  download "$TMP_DIR/mihomo.gz" "$url" || die "failed to download Mihomo"
  unpack_gzip_to "$TMP_DIR/mihomo.gz" "$TMP_DIR/mihomo" || die "failed to unpack Mihomo"

  chmod +x "$TMP_DIR/mihomo"

  "$TMP_DIR/mihomo" -v >/dev/null 2>&1 || die "downloaded Mihomo cannot run on this system"

  mv "$TMP_DIR/mihomo" "$MIHOMO_BIN"
  chmod +x "$MIHOMO_BIN"

  badge_ok "Installed: $MIHOMO_BIN"
  "$MIHOMO_BIN" -v | head -n 5
}

core_version() {
  banner
  small_header "Mihomo version"

  if [ -x "$MIHOMO_BIN" ]; then
    "$MIHOMO_BIN" -v
  else
    badge_warn "Mihomo is not installed"
    say "Run:"
    say "  ./goshacrash install-core"
  fi
}

test_config() {
  ensure_custom_files
  load_env

  if [ ! -x "$MIHOMO_BIN" ]; then
    die "Mihomo is not installed. Run: ./goshacrash install-core"
  fi

  if [ ! -f "$TARGET_CONFIG_FILE" ]; then
    generate_config >/dev/null 2>&1
  fi

  banner
  small_header "Test Mihomo config"

  "$MIHOMO_BIN" -t -d "$CONFIG_DIR" -f "$TARGET_CONFIG_FILE"
}

is_running() {
  if [ -f "$MIHOMO_PID_FILE" ]; then
    pid="$(cat "$MIHOMO_PID_FILE" 2>/dev/null)"
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
  fi

  return 1
}

start_core() {
  ensure_custom_files
  load_env
  init_dirs

  [ -x "$MIHOMO_BIN" ] || die "Mihomo is not installed. Run: ./goshacrash install-core"

  if [ ! -f "$TARGET_CONFIG_FILE" ]; then
    generate_config >/dev/null 2>&1
  fi

  if is_running; then
    banner
    badge_ok "Mihomo already running. PID: $(cat "$MIHOMO_PID_FILE")"
    return 0
  fi

  banner
  small_header "Start Mihomo"

  nohup "$MIHOMO_BIN" -d "$CONFIG_DIR" -f "$TARGET_CONFIG_FILE" > "$MIHOMO_LOG_FILE" 2>&1 &
  pid="$!"
  echo "$pid" > "$MIHOMO_PID_FILE"

  sleep 1

  if is_running; then
    badge_ok "Mihomo started. PID: $pid"
    say ""
    say "Proxy:     http://127.0.0.1:$MIHOMO_MIXED_PORT"
    say "API:       http://$MIHOMO_API_HOST:$MIHOMO_API_PORT"
    say "Dashboard: http://$MIHOMO_API_HOST:$MIHOMO_API_PORT/ui"
    say "DNS:       $MIHOMO_DNS_HOST:$MIHOMO_DNS_PORT"
  else
    badge_no "Mihomo failed to start"
    tail -n 80 "$MIHOMO_LOG_FILE" 2>/dev/null || true
    return 1
  fi
}

stop_core() {
  banner
  small_header "Stop Mihomo"

  if is_running; then
    pid="$(cat "$MIHOMO_PID_FILE")"
    kill "$pid" 2>/dev/null || true
    sleep 1

    if kill -0 "$pid" 2>/dev/null; then
      kill -9 "$pid" 2>/dev/null || true
    fi

    rm -f "$MIHOMO_PID_FILE"
    badge_ok "Stopped"
  else
    rm -f "$MIHOMO_PID_FILE"
    badge_warn "Mihomo is not running"
  fi
}

status_core() {
  banner
  small_header "Mihomo status"

  if is_running; then
    badge_ok "running"
    say "PID: $(cat "$MIHOMO_PID_FILE")"
  else
    badge_warn "stopped"
  fi

  if [ -x "$MIHOMO_BIN" ]; then
    say ""
    "$MIHOMO_BIN" -v | head -n 3
  fi
}

