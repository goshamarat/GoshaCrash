#!/bin/sh
# BUILD: 2026-07-13-slim-menu-070
# GoshaCrash 0.7.0 — slim installer and menu for Mihomo + Zashboard on stock ASUSWRT.
# Target: ASUS RT-AC68U, Download Master installed, USB-mounted installation.

VERSION="0.7.0-stock-asuswrt"
BUILD_ID="2026-07-13-slim-menu-070"
SHELLCRASH_REPO="${SHELLCRASH_REPO:-juewuy/ShellCrash}"
SHELLCRASH_BRANCH="${SHELLCRASH_BRANCH:-update}"

SCRIPT_DIR="$(CDPATH= cd "$(dirname "$0")" 2>/dev/null && pwd)"
BASE="${GOSHACRASH_BASE:-$SCRIPT_DIR}"
USB_MOUNT="$(dirname "$BASE")"
BIN="$BASE/bin/mihomo"
UI="$BASE/ui"
CONFIG="$BASE/config.yaml"
RUNTIME="$BASE/runtime.yaml"
PREVIOUS="$BASE/runtime.previous.yaml"
PIDFILE="$BASE/run/mihomo.pid"
LOGFILE="$BASE/logs/mihomo.log"
BACKUPS="$BASE/backups"
STATE="$BASE/state"

JFFS_BASE="/jffs/addons/goshacrash"
JFFS_BASE_FILE="$JFFS_BASE/base"
JFFS_DNS_MODE="$JFFS_BASE/dns.mode"
RESOLV="${STOCK_RESOLV_DNSMASQ:-/tmp/resolv.dnsmasq}"
RESOLV_BACKUP="$STATE/resolv.dnsmasq.original"
DNS_MARK="# GOSHACRASH_STOCK_DNS"
DNS_HOST="${MIHOMO_DNS_HOST:-127.0.0.1}"
DNS_PORT="${MIHOMO_DNS_PORT:-1053}"
DNS_BOOTSTRAP="${DNS_BOOTSTRAP:-9.9.9.9}"

TUN_DEVICE="${GOSHACRASH_TUN_DEVICE:-mihomo0}"
TUN_MTU="${GOSHACRASH_TUN_MTU:-1500}"
TUN_TABLE="${GOSHACRASH_TUN_TABLE:-2022}"
TUN_MARK="${GOSHACRASH_TUN_MARK:-0x2333}"
TUN_PREF="${GOSHACRASH_TUN_PREF:-10010}"
MANGLE_CHAIN="GOSHACRASH_TUN"
FILTER_CHAIN="GOSHACRASH_FORWARD"
DNS_CHAIN="GOSHACRASH_DNS_HIJACK"

PATH="/usr/sbin:/usr/bin:/sbin:/bin:/opt/bin:/opt/sbin:$USB_MOUNT/asusware.arm/bin:$USB_MOUNT/asusware.arm/sbin"
export PATH

say(){ printf '%s\n' "[GoshaCrash] $*"; }
warn(){ printf '%s\n' "[GoshaCrash:WARN] $*" >&2; }
fail(){ printf '%s\n' "[GoshaCrash:ERROR] $*" >&2; return 1; }
have(){ which "$1" >/dev/null 2>&1; }

ensure_dirs(){ mkdir -p "$BASE/bin" "$UI" "$BASE/run" "$BASE/logs" "$BACKUPS" "$STATE"; }

is_true(){
    case "$1" in true|True|TRUE|yes|Yes|YES|1|on|On|ON) return 0;; esac
    return 1
}

strip_value(){
    printf '%s\n' "$1" | sed -e 's/[[:space:]]*#.*$//' -e 's/^[[:space:]]*//' \
        -e 's/[[:space:]]*$//' -e 's/^"//' -e 's/"$//' -e "s/^'//" -e "s/'$//"
}

yaml_top(){
    f="$1"; k="$2"
    v="$(awk -v k="$k" '$0 ~ "^[[:space:]]*" k ":[[:space:]]*" {x=$0; sub("^[[:space:]]*" k ":[[:space:]]*","",x); print x; exit}' "$f" 2>/dev/null)"
    strip_value "$v"
}

yaml_section(){
    f="$1"; s="$2"; k="$3"
    v="$(awk -v s="$s" -v k="$k" '
        $0 ~ "^" s ":[[:space:]]*($|#)" {inside=1; next}
        inside && /^[^[:space:]#]/ {exit}
        inside && $0 ~ "^[[:space:]]+" k ":[[:space:]]*" {x=$0; sub("^[[:space:]]+" k ":[[:space:]]*","",x); print x; exit}
    ' "$f" 2>/dev/null)"
    strip_value "$v"
}

lan_ifaces(){
    [ -n "${GOSHACRASH_LAN_IFACES:-}" ] && { echo "$GOSHACRASH_LAN_IFACES"; return; }
    x="$(nvram get lan_ifname 2>/dev/null)"; [ -n "$x" ] || x=br0; echo "$x"
}

lan_ip(){ x="$(nvram get lan_ipaddr 2>/dev/null)"; [ -n "$x" ] || x=192.168.1.1; echo "$x"; }

fetch(){
    url="$1"; out="$2"; part="$out.part.$$"; log="/tmp/goshacrash-fetch.$$"
    rm -f "$part" "$out" "$log"

    if [ -x /usr/sbin/wget ]; then
        downloader=/usr/sbin/wget; kind=wget
    elif have wget; then
        downloader="$(which wget)"; kind=wget
    elif have curl; then
        downloader="$(which curl)"; kind=curl
    else
        fail "Не найден wget или curl"
        return 1
    fi

    say "Загрузчик: $downloader"
    if [ "$kind" = wget ]; then
        "$downloader" --no-check-certificate -O "$part" "$url" >"$log" 2>&1
    else
        "$downloader" -k -f -L -o "$part" "$url" >"$log" 2>&1
    fi
    rc=$?

    if [ "$rc" -eq 0 ] && [ -s "$part" ]; then
        mv -f "$part" "$out"
        rm -f "$log"
        return 0
    fi

    warn "Не удалось скачать $url"
    [ -s "$log" ] && cat "$log" >&2
    rm -f "$part" "$out" "$log"
    return 1
}


is_asus(){
    have nvram && [ -n "$(nvram get productid 2>/dev/null)" ] && return 0
    uname -a 2>/dev/null | grep -qiE 'asus|brcmarm'
}

core_arch(){
    case "$(uname -m 2>/dev/null)" in
        armv7l|armv7*|armhf)
            # ShellCrash uses armv5 on old ASUS armv7 devices to avoid crashes.
            if is_asus; then echo armv5; else echo armv7; fi;;
        armv5*|armv6*) echo armv5;;
        aarch64|arm64) echo arm64;;
        x86_64|amd64) echo amd64;;
        i?86|x86) echo 386;;
        *) fail "Неподдерживаемая архитектура: $(uname -m)"; return 1;;
    esac
}

install_core_from_shellcrash(){
    a="$1"; pkg="$BASE/run/mihomo-shellcrash.tar.gz"; ex="$BASE/run/mihomo.extract"; new="$BASE/run/mihomo.new"
    asset="clash-linux-$a.tar.gz"
    url="${MIHOMO_URL:-https://github.com/$SHELLCRASH_REPO/raw/$SHELLCRASH_BRANCH/bin/meta/$asset}"

    say "Скачиваю Mihomo: $url"
    fetch "$url" "$pkg" || return 1
    tar -tzf "$pkg" >/dev/null 2>&1 || { warn "Получен повреждённый архив Mihomo"; rm -f "$pkg"; return 1; }
    rm -rf "$ex"; mkdir -p "$ex" || return 1
    tar -xzf "$pkg" -C "$ex" >/dev/null 2>&1 || { rm -rf "$ex" "$pkg"; return 1; }

    candidate=""
    for f in "$ex/CrashCore" "$ex/clash" "$ex/mihomo" "$ex"/*; do
        [ -f "$f" ] || continue
        candidate="$f"
        break
    done
    [ -n "$candidate" ] && [ -f "$candidate" ] || { rm -rf "$ex" "$pkg"; fail "В архиве Mihomo не найден бинарник"; return 1; }

    cp "$candidate" "$new" || return 1
    chmod 755 "$new" || return 1
    "$new" -v >/dev/null 2>&1 || { warn "Скачанное ядро Mihomo не запускается"; rm -rf "$ex" "$pkg" "$new"; return 1; }
    rm -rf "$ex" "$pkg"
    return 0
}

install_core(){
    ensure_dirs || return 1
    a="$(core_arch)" || return 1
    new="$BASE/run/mihomo.new"
    rm -f "$new"

    say "Архитектура ядра: $a"
    install_core_from_shellcrash "$a" || {
        fail "Не удалось скачать рабочее ядро Mihomo из основного источника"
        return 1
    }

    [ -f "$BIN" ] && cp "$BIN" "$BIN.previous" 2>/dev/null || true
    mv -f "$new" "$BIN" || return 1
    chmod 755 "$BIN" || return 1
    say "Mihomo установлен: $($BIN -v 2>/dev/null | head -n 1)"
}

find_ui_root(){
    ex="$1"
    [ -f "$ex/index.html" ] && { echo "$ex"; return 0; }
    for d in "$ex"/*; do
        [ -d "$d" ] && [ -f "$d/index.html" ] && { echo "$d"; return 0; }
    done
    if have find; then
        idx="$(find "$ex" -name index.html -type f 2>/dev/null | head -n 1)"
        [ -n "$idx" ] && { dirname "$idx"; return 0; }
    fi
    return 1
}

install_ui(){
    ensure_dirs || return 1
    tgz="$BASE/run/zashboard.tar.gz"; ex="$BASE/run/zashboard.extract"; newui="$BASE/run/ui.new"
    rm -rf "$ex" "$newui"; mkdir -p "$ex" "$newui" || return 1

    url="${ZASHBOARD_URL:-https://github.com/$SHELLCRASH_REPO/raw/$SHELLCRASH_BRANCH/bin/dashboard/zashboard.tar.gz}"
    say "Скачиваю Zashboard: $url"
    fetch "$url" "$tgz" || return 1

    tar -tzf "$tgz" >/dev/null 2>&1 || { fail "Получен повреждённый архив Zashboard"; rm -f "$tgz"; return 1; }
    tar -xzf "$tgz" -C "$ex" >/dev/null 2>&1 || return 1
    root="$(find_ui_root "$ex")" || { fail "В архиве Zashboard нет index.html"; rm -rf "$ex" "$tgz"; return 1; }
    cp -R "$root"/. "$newui"/ || return 1
    [ -f "$newui/index.html" ] || return 1

    rm -rf "$UI.previous"
    [ -d "$UI" ] && mv "$UI" "$UI.previous" 2>/dev/null || true
    mv "$newui" "$UI" || { [ -d "$UI.previous" ] && mv "$UI.previous" "$UI"; return 1; }
    rm -rf "$ex" "$tgz"
    say "Zashboard установлен по сети"
}

